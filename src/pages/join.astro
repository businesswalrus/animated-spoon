---
// src/pages/join.astro — FORM AAR-100 · APPLICATION FOR ENROLLMENT
import MainLayout from '../layouts/MainLayout.astro';
import DocHero from '../components/DocHero.astro';
import CommentLedger from '../components/CommentLedger.astro';
import Stamp from '../components/Stamp.astro';
import Seal from '../components/Seal.astro';

const metaDescription =
  'File Form AAR-100 to enroll in AARBAA. Membership tiers, benefits, and processing information from the Bureau of Road Fairness.';

// Fee schedule — tier names, fees, and the benefits checklist port verbatim
// from the prior membership cards. Order: ROAD WARRIOR / FREEDOM FIGHTER / ROAD GENERAL.
const feeRows = [
  { benefit: 'Digital membership card', tiers: [true, true, true] },
  { benefit: 'Email updates and action alerts', tiers: [true, true, true] },
  { benefit: 'Access to members-only resources', tiers: [true, true, true] },
  { benefit: 'Voting rights for advocacy priorities', tiers: [true, true, true] },
  { benefit: 'AARBAA bumper sticker', tiers: [false, true, true] },
  { benefit: 'Quarterly print newsletter', tiers: [false, true, true] },
  { benefit: 'Exclusive AARBAA merchandise', tiers: [false, false, true] },
] as const;

const privileges = [
  {
    title: 'Amplify Your Voice',
    body: "As an AARBAA member, your frustrations with road cyclists don't just disappear into the void. We aggregate member concerns and present them to local government officials with the weight of thousands behind them.",
  },
  {
    title: 'Advocacy Resources',
    body: 'Get access to templates for contacting your representatives, talking points for city council meetings, and data-driven research to support common-sense road safety policies.',
  },
  {
    title: 'Community of Like-Minded Citizens',
    body: "Connect with others who've had enough of road biker entitlement. Share stories, strategies, and successes in our members-only forums and local chapter meetings.",
  },
  {
    title: 'Exclusive Updates',
    body: 'Stay informed with our newsletter featuring the latest in cyclist regulation policies, infrastructure development, and AARBAA victories across the country.',
  },
] as const;

const memberComments = [
  {
    quote:
      "Before AARBAA, I thought I was alone in my frustration. Now I'm part of a movement actually making changes in my town's road policies!",
    name: 'Sarah T.',
    location: 'Member since 2023',
  },
  {
    quote:
      'Our AARBAA chapter got the city to build a dedicated bike path parallel to Main Street. Now cyclists are safer and traffic flows normally again!',
    name: 'Robert J.',
    location: 'Chapter President, Denver',
  },
  {
    quote:
      "As both a driver and weekend cyclist, I appreciate AARBAA's balanced approach. I'm proud to support an organization fighting for real solutions.",
    name: 'Michelle K.',
    location: 'Freedom Fighter Member',
  },
] as const;
---

<MainLayout
  title="Application for Enrollment — AARBAA"
  description={metaDescription}
  docket="AAR-100 · ENROLLMENT DIVISION"
  formNumber="FORM AAR-100"
>
  <!-- ============ COVER SHEET ============ -->
  <DocHero
    title="APPLICATION FOR ENROLLMENT"
    kicker="FORM AAR-100"
    classification="FEE SCHEDULE ENCLOSED"
    subtitle="Become part of the solution to America's road biker problem"
  />

  <!-- ============ PART I — SCHEDULE OF FEES ============ -->
  <section class="file-section" aria-labelledby="fees-heading">
    <header class="section-head">
      <p class="kicker">PART I — SCHEDULE OF FEES · ANNUAL RATES EFFECTIVE 07/2026</p>
      <h2 id="fees-heading">CHOOSE YOUR MEMBERSHIP LEVEL</h2>
    </header>

    <div class="foldout">
      <table class="fee-schedule">
        <caption class="vh">Schedule of membership fees and benefits by tier</caption>
        <thead>
          <tr>
            <th scope="col" class="fee-benefit-col">SCHEDULE OF BENEFITS</th>
            <th scope="col" class="fee-tier">
              <span class="fee-tier__name">ROAD WARRIOR</span>
              <span class="fee-tier__price">$25<span class="fee-tier__per">/year</span></span>
            </th>
            <th scope="col" class="fee-tier fee-tier--popular">
              <span class="fee-tier__name">FREEDOM FIGHTER</span>
              <span class="fee-tier__price">$50<span class="fee-tier__per">/year</span></span>
              <span class="fee-tier__stamp">
                <Stamp text="MOST POPULAR" animated={false} rotate={-5} label="Most popular tier" />
              </span>
            </th>
            <th scope="col" class="fee-tier">
              <span class="fee-tier__seal"><Seal tone="gold" size="44px" /></span>
              <span class="fee-tier__name">ROAD GENERAL</span>
              <span class="fee-tier__price">$100<span class="fee-tier__per">/year</span></span>
            </th>
          </tr>
        </thead>
        <tbody>
          {
            feeRows.map((row) => (
              <tr>
                <th scope="row" class="fee-benefit">{row.benefit}</th>
                {row.tiers.map((included) => (
                  <td class={included ? 'fee-yes' : 'fee-no'}>
                    <span aria-hidden="true">{included ? '✓' : '—'}</span>
                    <span class="vh">{included ? 'Included' : 'Not included'}</span>
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
        <tfoot>
          <tr>
            <td class="fee-elect">ELECT ONE (1) TIER AND PROCEED TO THE FILING WINDOW</td>
            <td><a class="btn" href="#join-form">Select</a></td>
            <td><a class="btn btn--primary" href="#join-form">Select</a></td>
            <td><a class="btn" href="#join-form">Select</a></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </section>

  <!-- ============ PART II — MEMBER PRIVILEGES ============ -->
  <section class="file-section" aria-labelledby="privileges-heading">
    <header class="section-head">
      <p class="kicker">PART II — MEMBERSHIP BENEFITS</p>
      <h2 id="privileges-heading">SCHEDULE OF MEMBER PRIVILEGES</h2>
    </header>

    <ol class="privilege-list">
      {
        privileges.map((p, i) => (
          <li class="privilege">
            <span class="ghost privilege__ghost" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="privilege__title">{p.title}</h3>
            <p class="privilege__body">{p.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- ============ PART III — THE FILING WINDOW ============ -->
  <section id="join-form" class="file-section" aria-labelledby="filing-heading">
    <header class="section-head">
      <p class="kicker">PART III — THE FILING WINDOW</p>
      <h2 id="filing-heading">READY TO JOIN THE MOVEMENT?</h2>
    </header>
    <p class="section-lead">
      Complete the form below to become an official member of AARBAA and help us reclaim America's roads.
    </p>

    <div class="filing-window">
      <p class="filing-window__label">
        SUBMIT COMPLETED APPLICATION BELOW — APPLICATIONS PROCESSED IN ORDER RECEIVED
      </p>
      <iframe
        title="AARBAA membership application form"
        src="https://form.jotform.com/250919067322053"
        width="100%"
        height="600"
        frameborder="0"
        allow="fullscreen; geolocation; microphone; camera"
        style="border: none;"
      ></iframe>
    </div>
  </section>

  <!-- ============ PART IV — PUBLIC COMMENT RECORD ============ -->
  <section class="file-section" aria-labelledby="member-comments-heading">
    <header class="section-head">
      <p class="kicker">PART IV — COMMENTS OF ENROLLED MEMBERS</p>
      <h2 id="member-comments-heading">WHAT OUR MEMBERS SAY</h2>
    </header>

    <CommentLedger entries={memberComments} />
  </section>
</MainLayout>

<style>
  .file-section {
    padding: var(--s6) 0;
    border-bottom: 1px solid var(--rule);
  }

  .file-section:last-of-type {
    border-bottom: 0;
  }

  .section-lead {
    max-width: var(--measure);
    color: var(--ink-soft);
    font-size: var(--fs-md);
    margin: var(--s3) 0 var(--s4);
  }

  .vh {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---- Fee schedule (arrangement of the global .foldout table) ---- */
  .fee-schedule {
    width: 100%;
    min-width: 44rem;
    table-layout: fixed;
    border-collapse: collapse;
  }

  .fee-schedule th,
  .fee-schedule td {
    border: 1px solid var(--rule);
    padding: var(--s2);
    text-align: center;
    vertical-align: middle;
  }

  .fee-benefit-col {
    width: 30%;
  }

  .fee-tier {
    position: relative;
    background: var(--navy-deep);
    color: var(--paper);
  }

  .fee-tier--popular {
    background: var(--glory-red);
  }

  .fee-tier__name {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-lg);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fee-tier__price {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-2xl);
    line-height: 1.1;
    margin-top: var(--s1);
  }

  .fee-tier__per {
    font-family: var(--font-type);
    font-weight: 400;
    font-size: var(--fs-sm);
    letter-spacing: 0.05em;
  }

  .fee-tier__stamp {
    display: inline-block;
    margin-top: var(--s2);
  }

  /* Stamp ink multiplies to mud on the glory-red header; print it in paper. */
  .fee-tier--popular .fee-tier__stamp :global(.stamp) {
    color: var(--paper);
    mix-blend-mode: normal;
  }

  .fee-tier__seal {
    display: block;
    margin: 0 auto var(--s1);
    line-height: 0;
  }

  .fee-benefit {
    font-family: var(--font-type);
    font-weight: 400;
    font-size: var(--fs-sm);
    letter-spacing: 0.02em;
    text-align: left;
    background: var(--paper);
  }

  .fee-yes,
  .fee-no {
    font-family: var(--font-type);
    font-weight: 700;
    font-size: var(--fs-md);
  }

  .fee-yes {
    color: var(--glory-blue);
  }

  .fee-no {
    color: var(--rule);
  }

  .fee-elect {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-align: left;
    color: var(--ink-soft);
  }

  /* ---- Privileges: ruled list with ghost numerals ---- */
  .privilege-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .privilege {
    position: relative;
    overflow: hidden;
    padding: var(--s4) var(--s3) var(--s4) 0;
    border-top: 1px dotted var(--rule);
  }

  .privilege:first-child {
    border-top: 0;
  }

  .privilege__ghost {
    position: absolute;
    right: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 8.5rem;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .privilege__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-xl);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 var(--s2);
    position: relative;
  }

  .privilege__body {
    max-width: var(--measure);
    color: var(--ink-soft);
    margin: 0;
    position: relative;
  }

  /* ---- Filing window ---- */
  .filing-window {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s3);
    box-shadow: var(--shadow-sheet);
  }

  .filing-window__label {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--s2);
    margin: 0 0 var(--s3);
  }

  @media (max-width: 820px) {
    .file-section {
      padding: var(--s5) 0;
    }

    .privilege__ghost {
      font-size: 5.5rem;
    }
  }
</style>
