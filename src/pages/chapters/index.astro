---
import MainLayout from '../../layouts/MainLayout.astro';
import DocHero from '../../components/DocHero.astro';
import StatLedger from '../../components/StatLedger.astro';
import Stamp from '../../components/Stamp.astro';
import { STATES } from '../../data/states';

const pageTitle = 'Directory of Field Offices — AARBAA';
const pageDescription =
  'Find your local AARBAA chapter. With 50 state chapters and over 15,000 members nationwide, we are fighting for safer roads and better cycling infrastructure in your community.';

// Aggregate figures compiled from all reporting stations.
const totalMembers = STATES.reduce((sum, state) => sum + state.stats.members, 0);
const totalChapters = STATES.reduce((sum, state) => sum + state.stats.chapters, 0);
const totalVictories = STATES.reduce((sum, state) => sum + state.stats.victories, 0);

const directoryStats = [
  { value: totalMembers.toLocaleString(), label: 'MEMBERS NATIONWIDE' },
  { value: totalChapters.toLocaleString(), label: 'LOCAL CHAPTERS' },
  { value: totalVictories.toLocaleString(), label: 'RECORDED VICTORIES' },
];
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  docket="AAR-DIR · FIELD OPERATIONS"
  formNumber="DIRECTORY"
>
  <DocHero
    image="/images/protest.webp"
    imageAlt="AARBAA members assembled at a public demonstration for road fairness"
    kicker="FIELD OPERATIONS DIVISION"
    title="DIRECTORY OF FIELD OFFICES"
    subtitle="Find Your Local Chapter and Join the Movement"
    classification="ALL 50 STATIONS REPORTING"
  />

  <section class="doc-section file-section" aria-labelledby="impact-head">
    <div class="section-head">
      <p class="kicker">QUARTERLY FIGURES · CONSOLIDATED RETURNS</p>
      <h2 id="impact-head">OUR NATIONWIDE IMPACT</h2>
    </div>
    <StatLedger stats={directoryStats} />
  </section>

  <section class="doc-section file-section" aria-labelledby="registry-head">
    <div class="registry-stamp">
      <Stamp text="FILED WITHOUT COMMENT" rotate={-6} />
    </div>
    <div class="section-head">
      <p class="kicker">REGISTRY OF STATIONS · ALPHABETICAL BY STATE</p>
      <h2 id="registry-head">SELECT YOUR STATE</h2>
    </div>

    <div class="locate-office">
      <label class="locate-office__label" for="stateSearch">LOCATE YOUR FIELD OFFICE</label>
      <input
        type="search"
        id="stateSearch"
        class="locate-office__input"
        placeholder="Search for your state..."
        autocomplete="off"
        spellcheck="false"
      />
    </div>

    <div class="registry" id="stateRegistry">
      {
        STATES.map((state, i) => (
          <a
            class="registry__row"
            href={`/chapters/${state.slug}`}
            data-state-name={state.name.toLowerCase()}
          >
            <span class="registry__no">{`AAR-${state.abbreviation}-${String(i + 1).padStart(4, '0')}`}</span>
            <span class="registry__subject">{state.name}</span>
            <span class="leaders" aria-hidden="true"></span>
            <span class="registry__abstract">
              {state.stats.members.toLocaleString()} MEMBERS · {state.stats.chapters}{' '}
              {state.stats.chapters === 1 ? 'CHAPTER' : 'CHAPTERS'}
            </span>
          </a>
        ))
      }
    </div>

    <div id="noResults" class="no-results" style="display: none;">
      <p class="no-results__title">NO STATES FOUND</p>
      <p class="no-results__body">Try adjusting your search.</p>
    </div>
  </section>

  <section class="doc-section file-section" aria-labelledby="expand-head">
    <div class="section-head">
      <p class="kicker">NEW STATION REQUESTS · PUBLIC COUNTER</p>
      <h2 id="expand-head">DON'T SEE YOUR STATE?</h2>
    </div>
    <p class="doc-copy">
      We're always expanding! If you don't see a chapter in your state yet, be the first to bring
      AARBAA's mission to your community. Contact us to learn how to start a new chapter.
    </p>
    <div class="doc-actions">
      <a href="/contact" class="btn btn--primary">START A CHAPTER</a>
      <a href="/about" class="btn">LEARN MORE</a>
    </div>
  </section>
</MainLayout>

<style>
  .doc-section {
    position: relative;
    padding: var(--s6) 0;
    border-top: 1px solid var(--rule);
  }

  .doc-section:first-of-type {
    border-top: 0;
  }

  .section-head {
    margin-bottom: var(--s5);
  }

  .registry-stamp {
    position: absolute;
    top: var(--s4);
    right: var(--s2);
    z-index: 2;
  }

  .locate-office {
    margin-bottom: var(--s5);
    max-width: 480px;
  }

  .locate-office__label {
    display: block;
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    color: var(--ink-soft);
    margin-bottom: var(--s2);
  }

  .locate-office__input {
    width: 100%;
    font-family: var(--font-type);
    font-size: var(--fs-base);
    color: var(--ink);
    background: var(--paper-raised);
    border: 2px solid var(--ink);
    border-radius: 0;
    padding: var(--s3);
  }

  .locate-office__input:focus-visible {
    outline: 2px solid var(--glory-red);
    outline-offset: 2px;
  }

  .no-results {
    padding: var(--s6) var(--s4);
    border: 1px dashed var(--rule);
    text-align: center;
  }

  .no-results__title {
    font-family: var(--font-type);
    font-weight: 700;
    letter-spacing: 0.12em;
    margin-bottom: var(--s2);
  }

  .no-results__body {
    color: var(--ink-soft);
  }

  .doc-copy {
    max-width: var(--measure);
    font-size: var(--fs-md);
    line-height: 1.8;
    margin-bottom: var(--s4);
  }

  .doc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s3);
  }

  @media (max-width: 720px) {
    .doc-section {
      padding: var(--s5) 0;
    }

    .registry-stamp {
      position: static;
      margin-bottom: var(--s3);
    }
  }
</style>

<script>
  // Live registry filter — ported behavior from the previous chapters directory.
  const searchInput = document.getElementById('stateSearch') as HTMLInputElement | null;
  const registryRows = document.querySelectorAll<HTMLElement>('.registry__row[data-state-name]');
  const noResults = document.getElementById('noResults');
  const stateRegistry = document.getElementById('stateRegistry');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const searchTerm = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      registryRows.forEach((row) => {
        const stateName = row.getAttribute('data-state-name') || '';

        if (stateName.includes(searchTerm)) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });

      if (noResults && stateRegistry) {
        if (visibleCount === 0 && searchTerm !== '') {
          noResults.style.display = 'block';
          stateRegistry.style.display = 'none';
        } else {
          noResults.style.display = 'none';
          stateRegistry.style.display = '';
        }
      }
    });
  }
</script>
