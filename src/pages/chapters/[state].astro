---
import MainLayout from '../../layouts/MainLayout.astro';
import DocHero from '../../components/DocHero.astro';
import StatLedger from '../../components/StatLedger.astro';
import Stamp from '../../components/Stamp.astro';
import CommentLedger from '../../components/CommentLedger.astro';
import PendingRecords from '../../components/PendingRecords.astro';
import ContactForm from '../../components/ContactForm.astro';
import { STATES, type StateData } from '../../data/states';

export const prerender = true;

export async function getStaticPaths() {
  return STATES.map((state, index) => ({
    params: { state: state.slug },
    props: { state, index },
  }));
}

interface Props {
  state: StateData;
  index: number;
}

const { state, index } = Astro.props;

const docket = `AAR-${state.abbreviation}-${String(index + 1).padStart(4, '0')}`;
const pageTitle = `AARBAA ${state.name} Chapter`;
const pageDescription = `Join the AARBAA chapter in ${state.name}. ${state.stats.members} members strong with ${state.stats.chapters} local chapters advocating for safer roads and better cycling infrastructure.`;
const pageUrl = `https://aarbaa.com/chapters/${state.slug}`;

// Funding amounts are recorded in millions of dollars; formatted M/B/K per ledger style.
const formatFunding = (amount: number) =>
  amount < 1
    ? `$${(amount * 1000).toFixed(0)}K`
    : amount >= 1000
      ? `$${(amount / 1000).toFixed(1)}B`
      : `$${amount}M`;

const formatDate = (date: string) =>
  new Date(date)
    .toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
    .toUpperCase();

const now = new Date();

const chapterStats = [
  { value: state.stats.members.toLocaleString(), label: 'MEMBERS' },
  { value: state.stats.chapters.toLocaleString(), label: 'LOCAL CHAPTERS' },
  { value: state.stats.victories.toLocaleString(), label: 'VICTORIES' },
];

const extraOutcomes = state.victories.length - 3;

// Structured data: BreadcrumbList + FAQPage only.
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aarbaa.com' },
        { '@type': 'ListItem', position: 2, name: 'Chapters', item: 'https://aarbaa.com/chapters' },
        { '@type': 'ListItem', position: 3, name: state.name, item: pageUrl },
      ],
    },
    ...(state.faqs && state.faqs.length > 0
      ? [
          {
            '@type': 'FAQPage',
            '@id': `${pageUrl}#faq`,
            mainEntity: state.faqs.map((faq) => ({
              '@type': 'Question',
              name: faq.question,
              acceptedAnswer: { '@type': 'Answer', text: faq.answer },
            })),
          },
        ]
      : []),
  ],
};
---

<MainLayout title={pageTitle} description={pageDescription} docket={docket} formNumber="DOSSIER">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <DocHero
    image="/images/protest.webp"
    imageAlt={`AARBAA ${state.name} Chapter road safety advocacy`}
    eager={true}
    ghost={state.abbreviation}
    kicker={`FIELD OFFICE DOSSIER · DOCKET NO. ${docket}`}
    title={`${state.name.toUpperCase()} FIELD OFFICE`}
    subtitle={`${state.stats.members} Members Fighting for Safer Roads`}
    classification={`ACTIVE — ${state.capital.toUpperCase()} STATION`}
  />

  <nav class="crossref dossier-crossref" aria-label="Breadcrumb">
    <a href="/">HOME</a>
    <span aria-hidden="true">/</span>
    <a href="/chapters">FIELD OFFICES</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">{state.name.toUpperCase()}</span>
  </nav>

  <nav class="tab-strip" aria-label="Dossier sections">
    <a href="#figures">FIGURES</a>
    <a href="#personnel">PERSONNEL</a>
    <a href="#outcomes">OUTCOMES</a>
    <a href="#proceedings">PROCEEDINGS</a>
    <a href="#case-files">CASE FILES</a>
    <a href="#inquiries">INQUIRIES</a>
    <a href="#records">RECORDS</a>
  </nav>

  <section id="figures" class="doc-section file-section" aria-labelledby="figures-head">
    <div class="section-head">
      <p class="kicker">QUARTERLY FIGURES · DOCKET NO. {docket}</p>
      <h2 id="figures-head">{state.name.toUpperCase()} CHAPTER IMPACT</h2>
    </div>
    <StatLedger stats={chapterStats} />

    {
      state.localStats && (
        <>
          <h3 class="sub-head">{state.name.toUpperCase()} CYCLING SAFETY STATISTICS</h3>
          <div class="figures-ledger">
            <div class="figures-ledger__row">
              <span class="figures-ledger__label">
                CYCLING FATALITIES ({state.localStats.cyclingFatalities.year})
              </span>
              <span class="leaders" aria-hidden="true" />
              <span class="figures-ledger__value">{state.localStats.cyclingFatalities.count}</span>
              <span class="badge-tag">
                {state.localStats.cyclingFatalities.change} FROM PREVIOUS YEAR
              </span>
            </div>
            <div class="figures-ledger__row">
              <span class="figures-ledger__label">INFRASTRUCTURE MILES — PROTECTED</span>
              <span class="leaders" aria-hidden="true" />
              <span class="figures-ledger__value">
                {state.localStats.infrastructureMiles.protected.toLocaleString()} MI
              </span>
            </div>
            <div class="figures-ledger__row">
              <span class="figures-ledger__label">INFRASTRUCTURE MILES — UNPROTECTED</span>
              <span class="leaders" aria-hidden="true" />
              <span class="figures-ledger__value">
                {state.localStats.infrastructureMiles.unprotected.toLocaleString()} MI
              </span>
            </div>
            <div class="figures-ledger__row">
              <span class="figures-ledger__label">INFRASTRUCTURE MILES — PLANNED</span>
              <span class="leaders" aria-hidden="true" />
              <span class="figures-ledger__value">
                {state.localStats.infrastructureMiles.planned.toLocaleString()} MI
              </span>
            </div>
            <div class="figures-ledger__row">
              <span class="figures-ledger__label">
                FUNDING SECURED ({state.localStats.fundingSecured.year}) — FOR INFRASTRUCTURE
                IMPROVEMENTS
              </span>
              <span class="leaders" aria-hidden="true" />
              <span class="figures-ledger__value">
                {formatFunding(state.localStats.fundingSecured.amount)}
              </span>
            </div>
          </div>
        </>
      )
    }

    {
      state.rating && (
        <p class="satisfaction-line">
          PUBLIC SATISFACTION INDEX: {state.rating.average.toFixed(1)} / 5 —{' '}
          {state.rating.count.toLocaleString()} RESPONSES ON FILE
        </p>
      )
    }
  </section>

  <section id="personnel" class="doc-section file-section" aria-labelledby="personnel-head">
    <div class="section-head">
      <p class="kicker">PERSONNEL FILE · OFFICE OF FIELD OPERATIONS</p>
      <h2 id="personnel-head">CHAPTER LEADERSHIP</h2>
    </div>
    <div class="personnel-card">
      <div class="personnel-card__row">
        <span class="personnel-card__label">OFFICER IN CHARGE</span>
        <span class="personnel-card__value">{state.chapterPresident.name}</span>
      </div>
      <div class="personnel-card__row">
        <span class="personnel-card__label">STATION</span>
        <span class="personnel-card__value">Chapter President · {state.capital}</span>
      </div>
      <div class="personnel-card__row">
        <span class="personnel-card__label">ELECTRONIC MAIL</span>
        <span class="personnel-card__value">
          <a href={`mailto:${state.chapterPresident.email}`}>{state.chapterPresident.email}</a>
        </span>
      </div>
      <div class="personnel-card__row">
        <span class="personnel-card__label">TELEPHONE</span>
        <span class="personnel-card__value">{state.chapterPresident.phone}</span>
      </div>
    </div>
    <p class="doc-note">
      <strong>Join the {state.name} chapter!</strong> Contact our chapter president to get involved
      with local advocacy efforts.
    </p>
  </section>

  {
    state.testimonials && state.testimonials.length > 0 && (
      <section class="doc-section file-section" aria-labelledby="comments-head">
        <div class="section-head">
          <p class="kicker">PUBLIC COMMENT RECORD · ENTERED WITHOUT OBJECTION</p>
          <h2 id="comments-head">VOICES FROM {state.name.toUpperCase()}</h2>
        </div>
        <CommentLedger
          entries={state.testimonials.map((t) => ({
            quote: t.quote,
            name: t.author,
            location: t.city,
          }))}
        />
      </section>
    )
  }

  {
    state.featuredArticle && (
      <section class="doc-section file-section" aria-labelledby="memo-head">
        <div class="section-head">
          <p class="kicker">FEATURED MEMORANDUM · RECORDS DIVISION</p>
          <h2 id="memo-head">LATEST FROM {state.name.toUpperCase()}</h2>
        </div>
        <article class="memo-abstract">
          <p class="memo-abstract__tag">FEATURED STORY</p>
          <h3 class="memo-abstract__title">{state.featuredArticle.title}</h3>
          <p class="memo-abstract__excerpt">{state.featuredArticle.excerpt}</p>
          <a class="crossref" href={state.featuredArticle.link}>
            READ FULL STORY — REF. {state.featuredArticle.link}
          </a>
        </article>
      </section>
    )
  }

  {
    state.victories && state.victories.length > 0 && (
      <section id="outcomes" class="doc-section file-section" aria-labelledby="outcomes-head">
        <div class="section-head">
          <p class="kicker">CASE OUTCOMES · CLOSED FILES</p>
          <h2 id="outcomes-head">{state.name.toUpperCase()} INFRASTRUCTURE VICTORIES</h2>
        </div>
        <div class="outcomes">
          {state.victories.slice(0, 3).map((victory, i) => (
            <article class="outcome">
              <div class="outcome__stamp">
                <Stamp text="RESOLVED" animated={i === 0} rotate={i === 0 ? -6 : i === 1 ? 3 : -3} />
              </div>
              <div class="outcome__meta">
                <span class="badge-tag">{victory.category.toUpperCase()}</span>
                <span class="outcome__date">{formatDate(victory.date)}</span>
                <span class="outcome__location">{victory.location.toUpperCase()}</span>
              </div>
              <h3 class="outcome__title">{victory.title}</h3>
              <p class="outcome__desc">{victory.description}</p>
              <div class="outcome__impact">
                <span class="outcome__impact-label">IMPACT:</span>
                <p>{victory.impact}</p>
              </div>
            </article>
          ))}
        </div>
        {extraOutcomes > 0 && <p class="doc-more">+{extraOutcomes} ADDITIONAL OUTCOMES ON FILE</p>}
      </section>
    )
  }

  {
    state.upcomingEvents && state.upcomingEvents.length > 0 && (
      <section
        id="proceedings"
        class="doc-section file-section"
        aria-labelledby="proceedings-head"
      >
        <div class="section-head">
          <p class="kicker">SCHEDULED PROCEEDINGS · PUBLIC NOTICE</p>
          <h2 id="proceedings-head">UPCOMING EVENTS IN {state.name.toUpperCase()}</h2>
        </div>
        <div class="proceedings">
          {state.upcomingEvents.map((event) => {
            const concluded = new Date(event.date) < now;
            return (
              <article class="proceeding">
                <div class="proceeding__meta">
                  <p>
                    <span class="proceeding__label">DATE</span>
                    {formatDate(event.date)}
                  </p>
                  <p>
                    <span class="proceeding__label">TIME</span>
                    {event.time}
                  </p>
                  <p>
                    <span class="proceeding__label">VENUE</span>
                    {event.venue}
                  </p>
                  <p>
                    <span class="proceeding__label">ADDRESS</span>
                    {event.address}, {event.city}
                  </p>
                </div>
                <div class="proceeding__body">
                  <div class="proceeding__head">
                    <h3>{event.name}</h3>
                    <span class="badge-tag">{event.eventType.toUpperCase()}</span>
                  </div>
                  <p class="proceeding__desc">{event.description}</p>
                  {concluded ? (
                    <p class="proceeding__note">PROCEEDINGS CONCLUDED — MINUTES ON FILE</p>
                  ) : event.registrationRequired ? (
                    <p class="proceeding__note">REGISTRATION REQUIRED — FORM AAR-101</p>
                  ) : null}
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )
  }

  {
    state.infrastructureIssues && state.infrastructureIssues.length > 0 && (
      <section id="case-files" class="doc-section file-section" aria-labelledby="cases-head">
        <div class="section-head">
          <p class="kicker">INFRASTRUCTURE CASE FILES · OPEN MATTERS</p>
          <h2 id="cases-head">INFRASTRUCTURE ISSUES WE'RE ADDRESSING</h2>
        </div>
        <div class="case-files">
          {state.infrastructureIssues.map((issue) => (
            <article class="case-file">
              <div class="case-file__tags">
                <span class="badge-tag">{issue.severity.toUpperCase()} PRIORITY</span>
                <span class="badge-tag">{issue.status.replace('-', ' ').toUpperCase()}</span>
              </div>
              <h3 class="case-file__title">{issue.title}</h3>
              <p class="case-file__desc">{issue.description}</p>
              <dl class="case-file__details">
                <div>
                  <dt>LOCATION</dt>
                  <dd>{issue.location}</dd>
                </div>
                <div>
                  <dt>AFFECTED AREAS</dt>
                  <dd>{issue.affectedCities.join(', ')}</dd>
                </div>
                <div>
                  <dt>PROPOSED SOLUTION</dt>
                  <dd>{issue.proposedSolution}</dd>
                </div>
                <div>
                  <dt>LAST UPDATED</dt>
                  <dd>{formatDate(issue.lastUpdated)}</dd>
                </div>
              </dl>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    state.faqs && state.faqs.length > 0 && (
      <section id="inquiries" class="doc-section file-section" aria-labelledby="inquiries-head">
        <div class="section-head">
          <p class="kicker">PUBLIC COUNTER · RESPONSES PREPARED IN ADVANCE</p>
          <h2 id="inquiries-head">FREQUENTLY FILED INQUIRIES</h2>
        </div>
        <div class="inquiries">
          {state.faqs.map((faq, i) => (
            <details class="details-folder" open={i === 0}>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )
  }

  <section id="records" class="doc-section file-section" aria-labelledby="records-head">
    <div class="section-head">
      <p class="kicker">PHOTOGRAPHIC RECORDS · EVIDENCE LOCKER</p>
      <h2 id="records-head">{state.name.toUpperCase()} CHAPTER GALLERY</h2>
    </div>
    <PendingRecords docket={docket} count={5} />
  </section>

  <section class="doc-section file-section" aria-labelledby="join-head">
    <div class="section-head">
      <p class="kicker">FILE A REQUEST · FORM AAR-101</p>
      <h2 id="join-head">JOIN AARBAA {state.name.toUpperCase()}</h2>
    </div>
    <p class="doc-copy">
      Ready to make a difference in {state.name}? Fill out the form below to connect with your
      local chapter and start advocating for safer roads today!
    </p>
    <ContactForm prefilledState={state.name} formNumber="AAR-101" />
  </section>

  <section class="doc-section file-section" aria-labelledby="xref-head">
    <div class="section-head">
      <p class="kicker">CROSS-REFERENCES · RECORDS RETENTION SCHEDULE 7</p>
      <h2 id="xref-head">RELATED FILINGS</h2>
    </div>
    <ul class="xref-list">
      <li><a class="crossref" href="/resources">SEE: PUBLIC READING ROOM — /resources</a></li>
      <li>
        <a class="crossref" href="/join">SEE: FORM AAR-100 — APPLICATION FOR ENROLLMENT — /join</a>
      </li>
      <li><a class="crossref" href="/news">SEE: OFFICIAL RECORDS — MEMORANDA LOG — /news</a></li>
    </ul>
  </section>
</MainLayout>

<style>
  .dossier-crossref {
    margin: var(--s4) 0 var(--s3);
  }

  .tab-strip {
    margin-bottom: var(--s3);
  }

  .doc-section {
    position: relative;
    padding: var(--s6) 0;
    border-top: 1px solid var(--rule);
    scroll-margin-top: var(--s6);
  }

  .doc-section:first-of-type {
    border-top: 0;
  }

  .section-head {
    margin-bottom: var(--s4);
  }

  .sub-head {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin: var(--s5) 0 var(--s3);
  }

  .figures-ledger {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s2) var(--s4);
  }

  .figures-ledger__row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s2);
    padding: var(--s3) 0;
    border-bottom: 1px solid var(--rule);
  }

  .figures-ledger__row:last-child {
    border-bottom: 0;
  }

  .figures-ledger__label {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
  }

  .figures-ledger__value {
    font-family: var(--font-display);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-lg);
    letter-spacing: 0.04em;
  }

  .satisfaction-line {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin-top: var(--s4);
  }

  .personnel-card {
    border: 2px solid var(--ink);
    background: var(--paper-raised);
    max-width: 760px;
  }

  .personnel-card__row {
    display: grid;
    grid-template-columns: 220px 1fr;
    border-bottom: 1px solid var(--rule);
  }

  .personnel-card__row:last-child {
    border-bottom: 0;
  }

  .personnel-card__label {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    padding: var(--s3);
    border-right: 1px solid var(--rule);
  }

  .personnel-card__value {
    padding: var(--s3);
    overflow-wrap: anywhere;
  }

  .personnel-card__value a {
    color: var(--glory-red);
  }

  .doc-note {
    margin-top: var(--s4);
    max-width: var(--measure);
  }

  .memo-abstract {
    border: 1px solid var(--ink);
    background: var(--paper-raised);
    box-shadow: var(--shadow-sheet);
    padding: var(--s5);
    max-width: 760px;
  }

  .memo-abstract__tag {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    color: var(--glory-red);
    margin-bottom: var(--s2);
  }

  .memo-abstract__title {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--fs-xl);
    line-height: 1.15;
    margin-bottom: var(--s3);
  }

  .memo-abstract__excerpt {
    max-width: var(--measure);
    margin-bottom: var(--s4);
  }

  .outcomes {
    display: grid;
    gap: var(--s4);
  }

  .outcome {
    position: relative;
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s5);
    padding-right: calc(var(--s5) + 8rem);
  }

  .outcome__stamp {
    position: absolute;
    top: var(--s3);
    right: var(--s3);
  }

  .outcome__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--s3);
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin-bottom: var(--s3);
  }

  .outcome__title {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--fs-lg);
    line-height: 1.15;
    margin-bottom: var(--s3);
  }

  .outcome__desc {
    max-width: var(--measure);
    margin-bottom: var(--s4);
  }

  .outcome__impact {
    border-left: 3px solid var(--glory-red);
    padding: var(--s2) var(--s3);
  }

  .outcome__impact-label {
    display: block;
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--glory-red);
    margin-bottom: var(--s1);
  }

  .outcome__impact p {
    font-size: var(--fs-sm);
    max-width: var(--measure);
  }

  .doc-more {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.08em;
    margin-top: var(--s4);
  }

  .proceedings {
    display: grid;
    gap: var(--s4);
  }

  .proceeding {
    display: grid;
    grid-template-columns: 280px 1fr;
    border: 1px solid var(--rule);
    background: var(--paper);
  }

  .proceeding__meta {
    display: grid;
    gap: var(--s3);
    align-content: start;
    padding: var(--s4);
    border-right: 1px solid var(--rule);
    font-family: var(--font-type);
    font-size: var(--fs-sm);
  }

  .proceeding__label {
    display: block;
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    margin-bottom: var(--s1);
  }

  .proceeding__body {
    padding: var(--s4);
  }

  .proceeding__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s3);
    margin-bottom: var(--s3);
  }

  .proceeding__head h3 {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--fs-lg);
    line-height: 1.15;
  }

  .proceeding__desc {
    max-width: var(--measure);
  }

  .proceeding__note {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.06em;
    color: var(--glory-red);
    border-top: 1px dashed var(--rule);
    padding-top: var(--s3);
    margin-top: var(--s3);
  }

  .case-files {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 380px), 1fr));
    gap: var(--s4);
  }

  .case-file {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s4);
  }

