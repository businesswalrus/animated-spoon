---
// src/pages/shop.astro — GSA SURPLUS COMMISSARY — REQUISITION CATALOG
// Filed as: REQUISITION FORM · AAR-COM · COMMISSARY
import MainLayout from '../layouts/MainLayout.astro';
import DocHero from '../components/DocHero.astro';
import Stamp from '../components/Stamp.astro';
import Icon from '../components/Icon.astro';

interface Product {
  stock: string;
  name: string;
  category: string;
  price: number;
  description?: string;
  badge?: string;
  satisfaction?: string;
  responses?: string;
  sizes?: string;
  icon?: 'seal' | 'stamp' | 'folder' | 'gavel' | 'road-sign' | 'sedan' | 'document' | 'paperclip' | 'flag' | 'phone';
  plate?: boolean; // wordmark-on-navy plate instead of a glyph
}

const featured: Product[] = [
  {
    stock: 'STOCK NO. 8405-AAR-0001',
    name: '"ROADS ARE FOR CARS" T-SHIRT',
    category: 'APPAREL',
    badge: 'BESTSELLER',
    price: 24.99,
    description:
      'Make a bold statement in our signature red tee. Perfect for city council meetings, protests, or just daily wear.',
    satisfaction: '4.5 / 5',
    responses: '126',
    sizes: 'AVAILABLE SIZES: S · M · L · XL · XXL',
    plate: true,
  },
  {
    stock: 'STOCK NO. 8405-AAR-0002',
    name: 'AARBAA EMBROIDERED CAP',
    category: 'APPAREL',
    price: 19.99,
    description:
      'Premium adjustable cap with embroidered AARBAA logo. High-quality construction, unisex design.',
    satisfaction: '5 / 5',
    responses: '89',
    sizes: 'ONE SIZE FITS MOST',
    plate: true,
  },
  {
    stock: 'STOCK NO. 8405-AAR-0003',
    name: '"MORNING COMMUTER" COFFEE MUG',
    category: 'ACCESSORIES',
    badge: 'NEW',
    price: 15.99,
    description:
      'Start your morning right with a reminder of why you joined the cause. 15oz ceramic mug with AARBAA logo.',
    satisfaction: '4 / 5',
    responses: '42',
    plate: true,
  },
];

const apparel: Product[] = [
  { stock: 'STOCK NO. 8405-AAR-0004', name: '"SEPARATE PATHS" T-SHIRT', category: 'APPAREL', price: 22.99, icon: 'folder' },
  { stock: 'STOCK NO. 8405-AAR-0005', name: 'AARBAA POLO SHIRT', category: 'APPAREL', price: 32.99, icon: 'folder' },
  { stock: 'STOCK NO. 8405-AAR-0006', name: 'AARBAA TRUCKER HAT', category: 'APPAREL', price: 17.99, icon: 'folder' },
  { stock: 'STOCK NO. 8405-AAR-0007', name: 'WINTER BEANIE', category: 'APPAREL', price: 14.99, icon: 'folder' },
];

const accessories: Product[] = [
  { stock: 'STOCK NO. 8405-AAR-0008', name: 'BUMPER STICKER 3-PACK', category: 'ACCESSORIES', price: 8.99, icon: 'sedan' },
  { stock: 'STOCK NO. 8405-AAR-0009', name: 'INSULATED TRAVEL MUG', category: 'ACCESSORIES', price: 19.99, icon: 'folder' },
  { stock: 'STOCK NO. 8405-AAR-0010', name: 'PHONE CASE', category: 'ACCESSORIES', price: 16.99, icon: 'phone' },
  { stock: 'STOCK NO. 8405-AAR-0011', name: 'FOLDABLE WATER BOTTLE', category: 'ACCESSORIES', price: 12.99, icon: 'folder' },
];

const publications: Product[] = [
  {
    stock: 'STOCK NO. 8405-AAR-0012',
    name: 'ADVOCACY TOOLKIT (DIGITAL DOWNLOAD)',
    category: 'PUBLICATION',
    price: 14.99,
    description:
      'A comprehensive guide with templates, talking points, statistics, and practical advice for advocating at your local city council.',
    icon: 'document',
  },
  {
    stock: 'STOCK NO. 8405-AAR-0013',
    name: 'PRESENTATION PACKAGE (DIGITAL DOWNLOAD)',
    category: 'PUBLICATION',
    price: 19.99,
    description:
      'Ready-to-use presentation slides complete with speaker notes, data visualizations, and compelling arguments for separate bike paths.',
    icon: 'document',
  },
];

const schedules: { kicker: string; heading: string; lead: string; items: Product[] }[] = [
  {
    kicker: 'SCHEDULE A — FEATURED ITEMS',
    heading: 'Featured Products',
    lead: 'Our most popular items that make a statement',
    items: featured,
  },
  {
    kicker: 'SCHEDULE B — APPAREL',
    heading: 'Apparel',
    lead: 'Wear your support and spark conversations',
    items: apparel,
  },
  {
    kicker: 'SCHEDULE C — ACCESSORIES',
    heading: 'Accessories',
    lead: 'Show your support at home and on the road',
    items: accessories,
  },
  {
    kicker: 'PUBLICATIONS — NO COST',
    heading: 'Educational Resources',
    lead: 'Materials to help you advocate for better infrastructure',
    items: publications,
  },
];
---

<MainLayout
  title="Surplus Commissary — AARBAA"
  description="Requisition catalog of the AARBAA GSA Surplus Commissary. All items pending budget appropriation."
  docket="AAR-COM · COMMISSARY"
  formNumber="REQUISITION FORM"
>
  <DocHero
    kicker="GSA SURPLUS COMMISSARY"
    title="REQUISITION CATALOG"
    subtitle="Gear up to show your support for the cause"
    classification="FISCAL YEAR 2026"
  />

  <div class="commissary">
    <div class="commissary__catalog">
      {schedules.map((schedule) => (
        <section class="file-section" aria-label={schedule.kicker}>
          <div class="section-head">
            <p class="kicker">{schedule.kicker}</p>
            <h2>{schedule.heading}</h2>
          </div>
          <p class="schedule-lead">{schedule.lead}</p>

          <div class="req-list">
            {schedule.items.map((item) => (
              <article class="req-item" data-name={item.name} data-price={String(item.price)}>
                {item.plate ? (
                  <div class="req-item__plate req-item__plate--logo">
                    {item.badge && <span class="req-item__badge">{item.badge}</span>}
                    <img src="/images/aarbaa-logo.svg" alt="" loading="lazy" />
                  </div>
                ) : (
                  <div class="req-item__plate">
                    {item.badge && <span class="req-item__badge">{item.badge}</span>}
                    <Icon name={item.icon ?? 'folder'} size={36} />
                  </div>
                )}

                <div class="req-item__body">
                  <p class="req-item__stock">{item.stock} · {item.category}</p>
                  <h3 class="req-item__name">{item.name}</h3>
                  {item.description && <p class="req-item__desc">{item.description}</p>}
                  {item.satisfaction && (
                    <p class="req-item__meta">
                      PUBLIC SATISFACTION INDEX: {item.satisfaction} — {item.responses} RESPONSES ON FILE
                    </p>
                  )}
                  {item.sizes && <p class="req-item__meta">{item.sizes}</p>}

                  <div class="req-item__fee">
                    <span class="req-item__fee-label">UNIT FEE</span>
                    <span class="req-item__leader" aria-hidden="true"></span>
                    <span class="req-item__price">${item.price.toFixed(2)}</span>
                    <button type="button" class="btn add-to-req">ADD TO REQUISITION</button>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <!-- Shop updates — subscriptions handled by the footer mailing strip (Form AAR-102) -->
      <section class="file-section shop-updates">
        <div class="section-head">
          <p class="kicker">MAILING LIST — FORM AAR-102</p>
          <h2>Get Shop Updates</h2>
        </div>
        <p class="schedule-lead">
          Subscribe to our newsletter to receive updates on new merchandise and exclusive discounts
        </p>
        <p class="crossref">
          SUBSCRIPTION REQUESTS ARE ACCEPTED VIA THE MAILING LIST STRIP IN THE DOCUMENT FOOTER, FORM AAR-102.
        </p>
      </section>
    </div>

    <!-- REQUISITION FORM (cart) -->
    <aside class="commissary__cart" aria-label="Requisition form">
      <div class="cart-box">
        <h2 class="cart-box__title">REQUISITION FORM</h2>
        <p class="cart-box__sub">ITEMS YOU'VE SELECTED</p>

        <div id="empty-cart" class="cart-empty">
          <p class="cart-empty__head">Your cart is empty</p>
          <p>Add some items from our shop to get started</p>
        </div>

        <ul id="cart-item-list" class="cart-lines" hidden></ul>

        <div id="cart-totals" class="cart-totals" hidden>
          <div class="cart-totals__row">
            <span>Subtotal:</span>
            <span class="cart-totals__leader" aria-hidden="true"></span>
            <span id="cart-subtotal">$0.00</span>
          </div>
          <div class="cart-totals__row">
            <span>Shipping:</span>
            <span class="cart-totals__leader" aria-hidden="true"></span>
            <span id="cart-shipping">$5.99</span>
          </div>
          <div class="cart-totals__row cart-totals__row--grand">
            <span>Total:</span>
            <span class="cart-totals__leader" aria-hidden="true"></span>
            <span id="cart-total">$0.00</span>
          </div>
          <p class="cart-totals__note">
            <em>Note: This is a satirical shop. No items will actually be shipped.</em>
          </p>
          <button type="button" id="checkout-btn" class="btn btn--primary cart-checkout">
            PROCEED TO CHECKOUT
          </button>
        </div>

        <div id="denial-notice" class="cart-denial" role="status" hidden>
          <Stamp
            text="DENIED — PENDING BUDGET APPROPRIATION"
            rotate={-5}
            label="Requisition denied, pending budget appropriation"
          />
          <p class="cart-denial__note">
            NOTICE TO REQUISITIONER: This is a satirical shop. The listed products do not
            exist, and no items will be shipped. This requisition is denied pending budget
            appropriation. No further action is required on your part.
          </p>
        </div>
      </div>
    </aside>
  </div>
</MainLayout>

<style>
  /* Page arrangement only — all pattern styling lives in global.css. */
  .commissary {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--s5);
    margin-block: var(--s5) var(--s6);
    align-items: start;
  }

  @media (min-width: 960px) {
    .commissary {
      grid-template-columns: minmax(0, 1fr) 18rem;
    }

    .commissary__cart {
      position: sticky;
      top: var(--s4);
    }
  }

  .commissary__catalog > section + section {
    margin-top: var(--s6);
  }

  .schedule-lead {
    color: var(--ink-soft);
    max-width: var(--measure);
    margin-bottom: var(--s4);
  }

  /* — Requisition line items — */
  .req-list {
    border-top: 2px solid var(--ink);
  }

  .req-item {
    display: grid;
    grid-template-columns: 6.5rem minmax(0, 1fr);
    gap: var(--s4);
    border-bottom: 1px solid var(--rule);
    padding-block: var(--s4);
  }

  @media (max-width: 540px) {
    .req-item {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .req-item__plate {
    position: relative;
    display: grid;
    place-items: center;
    background: var(--navy-deep);
    color: var(--paper);
    min-height: 6.5rem;
    border: 1px solid var(--rule);
  }

  .req-item__plate--logo img {
    width: 4.5rem;
    height: auto;
    display: block;
  }

  .req-item__badge {
    position: absolute;
    top: -0.5rem;
    left: -0.5rem;
    background: var(--stamp-red);
    color: var(--paper-raised);
    font-family: var(--font-type);
    font-weight: 700;
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
  }

  .req-item__stock {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    margin-bottom: var(--s1);
  }

  .req-item__name {
    font-size: var(--fs-lg);
    margin-bottom: var(--s2);
  }

  .req-item__desc {
    max-width: var(--measure);
    margin-bottom: var(--s2);
  }

  .req-item__meta {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    margin-bottom: var(--s1);
  }

  .req-item__fee {
    display: flex;
    align-items: center;
    gap: var(--s3);
    margin-top: var(--s3);
    flex-wrap: wrap;
  }

  .req-item__fee-label {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-soft);
  }

  .req-item__leader {
    flex: 1 1 2rem;
    border-bottom: 2px dotted var(--rule);
    align-self: center;
    min-width: 2rem;
  }

  .req-item__price {
    font-family: var(--font-display);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-md);
  }

  /* — Requisition form (cart) — */
  .cart-box {
    background: var(--paper);
    border: 2px solid var(--ink);
    padding: var(--s4);
  }

  .cart-box__title {
    font-size: var(--fs-lg);
    border-bottom: 2px solid var(--ink);
    padding-bottom: var(--s2);
  }

  .cart-box__sub {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    color: var(--ink-soft);
    margin-block: var(--s2) var(--s3);
  }

  .cart-empty {
    border: 1px dashed var(--rule);
    padding: var(--s4);
    text-align: center;
  }

  .cart-empty__head {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--s1);
  }

  .cart-empty p:last-child {
    font-size: var(--fs-sm);
    color: var(--ink-soft);
  }

  .cart-lines {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--s3) 0;
  }

  .cart-lines :global(.cart-line) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: var(--s2);
    align-items: baseline;
    border-bottom: 1px dotted var(--rule);
    padding-block: var(--s2);
    font-family: var(--font-type);
    font-size: var(--fs-sm);
  }

  .cart-lines :global(.cart-line__name) {
    grid-column: 1;
  }

  .cart-lines :global(.cart-line__qty) {
    grid-column: 1;
    font-size: var(--fs-xs);
    color: var(--ink-soft);
  }

  .cart-lines :global(.cart-line__price) {
    font-variant-numeric: tabular-nums;
    font-weight: 700;
  }

  .cart-lines :global(.cart-line__remove) {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--glory-red);
    background: none;
    border: 1px solid var(--glory-red);
    padding: 0.1rem 0.4rem;
    cursor: pointer;
  }

  .cart-totals__row {
    display: flex;
    align-items: baseline;
    gap: var(--s2);
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    padding-block: var(--s1);
  }

  .cart-totals__leader {
    flex: 1;
    border-bottom: 2px dotted var(--rule);
  }

  .cart-totals__row span:last-child {
    font-variant-numeric: tabular-nums;
    font-weight: 700;
  }

  .cart-totals__row--grand {
    border-top: 1px solid var(--ink);
    margin-top: var(--s2);
    padding-top: var(--s2);
    font-size: var(--fs-base);
  }

  .cart-totals__note {
    font-size: var(--fs-xs);
    color: var(--ink-soft);
    margin-block: var(--s3);
  }

  .cart-checkout {
    width: 100%;
  }

  .cart-denial {
    margin-top: var(--s4);
    text-align: center;
  }

  .cart-denial__note {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    text-align: left;
    border-top: 1px solid var(--rule);
    margin-top: var(--s3);
    padding-top: var(--s3);
  }

  .shop-updates .crossref {
    margin-top: var(--s3);
  }
</style>

<script>
  // Requisition (cart) ledger — vanilla port of the old shop cart, alerts abolished.
  interface CartItem {
    id: number;
    name: string;
    price: number;
  }

  const addButtons = document.querySelectorAll<HTMLButtonElement>('.add-to-req');
  const emptyCart = document.getElementById('empty-cart');
  const cartItemList = document.getElementById('cart-item-list');
  const cartTotals = document.getElementById('cart-totals');
  const cartSubtotal = document.getElementById('cart-subtotal');
  const cartShipping = document.getElementById('cart-shipping');
  const cartTotal = document.getElementById('cart-total');
  const checkoutBtn = document.getElementById('checkout-btn') as HTMLButtonElement | null;
  const denialNotice = document.getElementById('denial-notice');

  let cartItems: CartItem[] = [];
  let nextId = 1;

  addButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const card = button.closest<HTMLElement>('.req-item');
      const name = card?.dataset.name ?? 'AARBAA Product';
      const price = Number.parseFloat(card?.dataset.price ?? '19.99');

      addItemToCart(name, price);

      // Inline Courier confirmation replaces the old alert().
      const originalText = button.textContent;
      button.textContent = 'ITEM LOGGED';
      button.disabled = true;
      window.setTimeout(() => {
        button.textContent = originalText;
        button.disabled = false;
      }, 1600);
    });
  });

  function addItemToCart(name: string, price: number): void {
    if (!emptyCart || !cartItemList || !cartTotals) return;

    const item: CartItem = { id: nextId++, name, price };
    cartItems.push(item);

    emptyCart.hidden = true;
    cartItemList.hidden = false;
    cartTotals.hidden = false;

    const li = document.createElement('li');
    li.className = 'cart-line';
    li.dataset.id = String(item.id);

    const nameEl = document.createElement('span');
    nameEl.className = 'cart-line__name';
    nameEl.textContent = name;

    const qtyEl = document.createElement('span');
    qtyEl.className = 'cart-line__qty';
    qtyEl.textContent = 'QTY: 1';

    const priceEl = document.createElement('span');
    priceEl.className = 'cart-line__price';
    priceEl.textContent = `$${price.toFixed(2)}`;

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'cart-line__remove';
    removeBtn.textContent = 'STRIKE';
    removeBtn.setAttribute('aria-label', `Remove ${name} from requisition`);
    removeBtn.addEventListener('click', () => removeItemFromCart(item.id));

    li.append(nameEl, priceEl, removeBtn, qtyEl);
    cartItemList.appendChild(li);

    updateCartTotals();
  }

  function removeItemFromCart(id: number): void {
    if (!emptyCart || !cartItemList || !cartTotals) return;

    cartItems = cartItems.filter((item) => item.id !== id);

    const itemElement = cartItemList.querySelector(`.cart-line[data-id="${id}"]`);
    if (itemElement) itemElement.remove();

    if (cartItems.length === 0) {
      emptyCart.hidden = false;
      cartItemList.hidden = true;
      cartTotals.hidden = true;
    }

    updateCartTotals();
  }

  function updateCartTotals(): void {
    const subtotal = cartItems.reduce((total, item) => total + item.price, 0);
    const shipping = cartItems.length > 0 ? 5.99 : 0;
    const total = subtotal + shipping;

    if (cartSubtotal) cartSubtotal.textContent = `$${subtotal.toFixed(2)}`;
    if (cartShipping) cartShipping.textContent = `$${shipping.toFixed(2)}`;
    if (cartTotal) cartTotal.textContent = `$${total.toFixed(2)}`;
  }

  // Checkout stamps the requisition DENIED — the page's one animated stamp
  // thunks when the notice is revealed. Replaces the old alert().
  checkoutBtn?.addEventListener('click', () => {
    if (denialNotice) denialNotice.hidden = false;
    checkoutBtn.disabled = true;
    checkoutBtn.textContent = 'REQUISITION SUBMITTED';
  });
</script>
