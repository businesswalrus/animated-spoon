---
// src/pages/news/index.astro
// OFFICIAL RECORDS — MEMORANDA LOG. A ruled registry table; cards abolished.
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import DocHero from '../../components/DocHero.astro';
import Stamp from '../../components/Stamp.astro';

const entries = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d
    .toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
    .toUpperCase();

interface Row {
  no: string;
  date: Date;
  title: string;
  abstract: string;
  href?: string;
  sealed?: boolean;
}

const rows: Row[] = entries.map((entry) => ({
  no: entry.data.memoNo,
  date: entry.data.date,
  title: entry.data.title,
  abstract: entry.data.excerpt,
  href: `/news/${entry.id}/`,
}));

// The record whose memorandum was never filed. The registry row is canon;
// the file itself remains sealed.
const sealedRow: Row = {
  no: 'MEMO 2025-0301-A',
  date: new Date(Date.UTC(2025, 2, 1)),
  title: 'STRATEGIC VICTORY: Downtown Bike Lane Proposal CRUSHED',
  abstract:
    'The proposed 12-mile bike lane network was reduced to a much more sensible 2-mile connector between existing paths, saving taxpayers millions...',
  sealed: true,
};

// File the sealed record in chronological position.
let insertAt = rows.findIndex((r) => r.date.valueOf() < sealedRow.date.valueOf());
if (insertAt === -1) insertAt = rows.length;
rows.splice(insertAt, 0, sealedRow);
---

<MainLayout
  title="Official Records — AARBAA"
  description="Memoranda log of the Bureau of Road Fairness: official AARBAA battle reports, studies, and legislative records."
  docket="AAR-REC · RECORDS DIVISION"
  formNumber="RECORDS INDEX"
>
  <DocHero
    kicker="RECORDS DIVISION"
    title="OFFICIAL RECORDS — MEMORANDA LOG"
    subtitle="AARBAA BATTLE REPORTS — Updates from the front lines of our fight against road cyclist entitlement"
  />

  <p class="crossref registry-note">
    THE FOLLOWING MEMORANDA ARE ENTERED INTO THE PUBLIC RECORD IN REVERSE ORDER OF FILING.
  </p>

  <div class="registry" role="list">
    {
      rows.map((row) => (
        <article class="registry__row file-section" role="listitem">
          <div class="registry__no">
            <span>{row.no}</span>
            <span class="leaders" aria-hidden="true" />
            <span>{fmt(row.date)}</span>
          </div>
          <h2 class="registry__subject">
            {row.href ? <a href={row.href}>{row.title}</a> : row.title}
          </h2>
          <p class="registry__abstract">{row.abstract}</p>
          {row.sealed && (
            <div class="registry__seal">
              <Stamp
                text="SEALED"
                rotate={-4}
                animated={false}
                label="Record sealed: memorandum not released"
              />
              <p class="registry__seal-note">
                MEMORANDUM WITHHELD FROM PUBLIC RELEASE UNDER RECORDS RETENTION SCHEDULE 7.
              </p>
            </div>
          )}
        </article>
      ))
    }
  </div>

  <p class="crossref registry-note">
    MAILING LIST FILINGS: SEE FORM AAR-102 BELOW.
  </p>
</MainLayout>

<style>
  /* Arrangement only — .registry pattern styling lives in global.css. */
  .registry-note {
    margin: var(--s4) 0;
  }

  .registry__seal {
    display: flex;
    align-items: center;
    gap: var(--s3);
    margin-top: var(--s2);
  }

  .registry__seal-note {
    margin: 0;
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    max-width: 42ch;
  }

  @media (max-width: 720px) {
    .registry__seal {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
