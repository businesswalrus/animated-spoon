---
// src/pages/thank-you.astro — FORM AAR-101-R · RECEIPT OF FILING
import MainLayout from '../layouts/MainLayout.astro';
import Stamp from '../components/Stamp.astro';
import Figure from '../components/Figure.astro';

const metaDescription =
  'Receipt of filing issued by the Bureau of Road Fairness. Your correspondence has been received and assigned to the processing queue.';
---

<MainLayout
  title="Receipt of Filing — AARBAA"
  description={metaDescription}
  docket="AAR-101-R · RECEIPTS"
  formNumber="FORM AAR-101-R"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <section class="file-section" aria-labelledby="receipt-heading">
    <article class="receipt">
      <!-- THE STAMP — one animated stamp per page; this is it -->
      <div class="receipt__stamp">
        <Stamp text="RECEIVED" variant="red" rotate={-5} label="Received" />
      </div>

      <header class="receipt__head">
        <p class="kicker">FORM AAR-101-R — RECEIPT OF FILING</p>
        <h1 id="receipt-heading" class="receipt__title">Thank You!</h1>
        <p class="receipt__date">DATE OF RECEIPT: <span id="receiptDate">PENDING ENTRY</span></p>
      </header>

      <div class="receipt__body">
        <p class="receipt__lead">
          Your message has been received. We appreciate you taking the time to contact AARBAA.
        </p>
        <p class="receipt__note">
          Your submission enters the queue at its filed position. Estimated time to first review: 6–8
          WEEKS. The Bureau does not expedite.
        </p>

        <!-- PERSONALIZED RECEIPT SUMMARY — ids and behavior preserved verbatim -->
        <div id="personalMessage" class="personal-message">
          <p>
            <strong>Thank you, <span id="userName"></span>!</strong> We've received your message and will
            respond to <span id="userEmail"></span> soon.
          </p>
        </div>

        <!-- DOCKET ASSIGNMENT — entered by the clerk (client-side) on issuance -->
        <p class="receipt__docket" id="docketLine" hidden></p>

        <div class="receipt__actions">
          <a class="btn btn--primary" href="/">Return to Home</a>
          <a class="btn" href="/news/">Read Latest News</a>
        </div>
      </div>

      <!-- CROSS-REFERENCE CITATIONS -->
      <footer class="receipt__more">
        <h2 class="receipt__more-title">While You're Here...</h2>

        <ul class="citations">
          <li class="citation">
            <h3 class="citation__title">Join AARBAA</h3>
            <p class="citation__body">Become part of our 15,000+ member community</p>
            <a class="crossref" href="/join/">Join Now</a>
          </li>
          <li class="citation">
            <h3 class="citation__title">Share Our Mission</h3>
            <p class="citation__body">Help spread the word about road safety</p>
            <button class="crossref citation__btn" id="shareBtn" type="button">Copy Citation</button>
            <span class="citation__confirm" id="shareConfirm" hidden aria-live="polite"
              >CITATION COPIED TO CLIPBOARD</span
            >
          </li>
          <li class="citation">
            <h3 class="citation__title">Newsletter</h3>
            <p class="citation__body">Get updates on our latest campaigns</p>
            <button class="crossref citation__btn" id="newsletterBtn" type="button">Subscribe</button>
          </li>
        </ul>
      </footer>
    </article>

    <!-- EXHIBIT W -->
    <div class="exhibit-w">
      <Figure
        src="/images/walrus-pennyfarthing.png"
        alt="Illustration of a walrus in a pinstripe suit riding a penny-farthing bicycle"
        caption="EXHIBIT W — ARTIST'S DEPICTION OF COMPLIANT CYCLING (SPECIES NON-REPRESENTATIVE). OFFICE OF CIVIC ENGAGEMENT"
        tilt="right"
        width={588}
        height={441}
      />
    </div>
  </section>
</MainLayout>

<style>
  .file-section {
    padding: var(--s6) 0;
  }

  .receipt {
    position: relative;
    max-width: 46rem;
    margin: 0 auto;
    border: 1px solid var(--rule);
    background: var(--paper);
    box-shadow: var(--shadow-sheet);
    padding: var(--s5) var(--s5) var(--s4);
  }

  .receipt__stamp {
    position: absolute;
    top: var(--s3);
    right: var(--s4);
    z-index: 2;
  }

  .receipt__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-2xl);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: var(--s2) 0;
  }

  .receipt__date {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    border-bottom: 2px solid var(--ink);
    padding-bottom: var(--s3);
    margin: 0 0 var(--s4);
  }

  .receipt__lead {
    font-size: var(--fs-md);
    max-width: var(--measure);
    margin: 0 0 var(--s2);
  }

  .receipt__note {
    color: var(--ink-soft);
    margin: 0 0 var(--s4);
  }

  .personal-message {
    display: none;
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    line-height: 1.7;
    background: var(--paper-raised);
    border: 1px solid var(--rule);
    border-left: 5px solid var(--glory-red);
    padding: var(--s3) var(--s4);
    margin: 0 0 var(--s3);
  }

  .personal-message p {
    margin: 0;
  }

  .receipt__docket {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
    color: var(--glory-blue);
    border: 1px dotted var(--rule);
    padding: var(--s2) var(--s3);
    margin: 0 0 var(--s4);
  }

  .receipt__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s3);
    margin: var(--s4) 0;
  }

  /* ---- While You're Here — cross-reference citations ---- */
  .receipt__more {
    border-top: 1px solid var(--rule);
    padding-top: var(--s4);
  }

  .receipt__more-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-lg);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 var(--s4);
  }

  .citations {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--s4);
    margin: 0;
    padding: 0;
  }

  .citation__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-base);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 var(--s1);
  }

  .citation__body {
    color: var(--ink-soft);
    font-size: var(--fs-sm);
    margin: 0 0 var(--s2);
  }

  .citation__btn {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font: inherit;
  }

  .citation__confirm {
    display: block;
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--glory-blue);
    margin-top: var(--s2);
  }

  .exhibit-w {
    max-width: 30rem;
    margin: var(--s6) auto 0;
  }

  @media (max-width: 720px) {
    .file-section {
      padding: var(--s5) 0;
    }

    .receipt {
      padding: var(--s4) var(--s3);
    }

    .receipt__stamp {
      position: static;
      margin-bottom: var(--s3);
    }

    .citations {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Check if we have form data from the contact form
  document.addEventListener('DOMContentLoaded', () => {
    const formData = sessionStorage.getItem('contactFormData');

    if (formData) {
      try {
        const data = JSON.parse(formData);
        const personalMessage = document.getElementById('personalMessage');
        const userName = document.getElementById('userName');
        const userEmail = document.getElementById('userEmail');

        if (data.name && data.email && personalMessage && userName && userEmail) {
          userName.textContent = data.name;
          userEmail.textContent = data.email;
          personalMessage.style.display = 'block';
        }

        // Clear the data after displaying
        sessionStorage.removeItem('contactFormData');
      } catch (e) {
        console.error('Error parsing form data:', e);
      }
    }
  });
</script>

<script>
  // Clerk duties: date of receipt, docket assignment, citation copying,
  // and routing to the FORM AAR-102 mailing strip in the document footer.
  document.addEventListener('DOMContentLoaded', () => {
    const receiptDate = document.getElementById('receiptDate');
    if (receiptDate) {
      receiptDate.textContent = new Date()
        .toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
        .toUpperCase();
    }

    const docketLine = document.getElementById('docketLine');
    if (docketLine) {
      docketLine.textContent =
        'Your correspondence has been assigned Docket No. AAR-C-' + String(Date.now()).slice(-6);
      docketLine.hidden = false;
    }

    const shareBtn = document.getElementById('shareBtn');
    const shareConfirm = document.getElementById('shareConfirm');
    if (shareBtn && shareConfirm) {
      shareBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.origin);
          shareConfirm.textContent = 'CITATION COPIED TO CLIPBOARD';
        } catch {
          shareConfirm.textContent = 'CLIPBOARD UNAVAILABLE — CITE ' + window.location.origin;
        }
        shareConfirm.hidden = false;
      });
    }

    const newsletterBtn = document.getElementById('newsletterBtn');
    if (newsletterBtn) {
      newsletterBtn.addEventListener('click', () => {
        const footer = document.querySelector('.doc-footer');
        if (footer) {
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          footer.scrollIntoView(reduce ? undefined : { behavior: 'smooth' });
          const emailInput = footer.querySelector('input[type="email"]');
          if (emailInput instanceof HTMLInputElement) emailInput.focus({ preventScroll: true });
        }
      });
    }
  });
</script>
