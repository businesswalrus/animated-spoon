---
import MainLayout from '../../layouts/MainLayout.astro';
import DocHero from '../../components/DocHero.astro';
import StatLedger from '../../components/StatLedger.astro';
import Stamp from '../../components/Stamp.astro';
import CommentLedger from '../../components/CommentLedger.astro';
import PendingRecords from '../../components/PendingRecords.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getAllCountrySlugs, getCountryData, type CountryData } from '../../data/countries';

export const prerender = true;

export async function getStaticPaths() {
  return getAllCountrySlugs().map((slug) => ({
    params: { country: slug },
    props: { country: getCountryData(slug)! },
  }));
}

interface Props {
  country: CountryData;
}

const { country } = Astro.props;

const docket = `AAR-INTL-${country.code}`;
const pageTitle = `AARBAA ${country.name} - International Chapter`;
const pageDescription = `Join AARBAA's international chapter in ${country.name}. ${country.stats.members} members across ${country.stats.chapters} chapters advocating for balanced road safety policy and motorists' rights.`;
const pageUrl = `https://aarbaa.com/countries/${country.slug}`;

// Ported helper: format funding in the desk's local currency.
const formatCurrency = (amount: number, currency: string) => {
  const symbols: Record<string, string> = {
    USD: '$',
    GBP: '£',
    CAD: 'CA$',
    AUD: 'AU$',
    EUR: '€',
  };
  return `${symbols[currency] || currency} ${(amount / 1000000).toFixed(1)}M`;
};

// Ported helper: format a single date or a date range.
const formatDateRange = (date: string, endDate?: string) => {
  const start = new Date(date);
  const options: Intl.DateTimeFormatOptions = { month: 'short', day: 'numeric', year: 'numeric' };

  if (endDate) {
    const end = new Date(endDate);
    if (start.getMonth() === end.getMonth()) {
      return `${start.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} - ${end.getDate()}, ${start.getFullYear()}`;
    }
    return `${start.toLocaleDateString('en-US', options)} - ${end.toLocaleDateString('en-US', options)}`;
  }

  return start.toLocaleDateString('en-US', options);
};

const formatDate = (date: string) =>
  new Date(date)
    .toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
    .toUpperCase();

const now = new Date();

const deskStats = [
  { value: country.stats.members.toLocaleString(), label: 'MEMBERS' },
  { value: country.stats.chapters.toLocaleString(), label: 'LOCAL CHAPTERS' },
  { value: country.stats.victories.toLocaleString(), label: 'VICTORIES' },
];

const extraOutcomes = country.victories.length - 3;

// Structured data: BreadcrumbList + FAQPage only.
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aarbaa.com' },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'International',
          item: 'https://aarbaa.com/countries',
        },
        { '@type': 'ListItem', position: 3, name: country.name, item: pageUrl },
      ],
    },
    ...(country.faqs && country.faqs.length > 0
      ? [
          {
            '@type': 'FAQPage',
            '@id': `${pageUrl}#faq`,
            mainEntity: country.faqs.map((faq) => ({
              '@type': 'Question',
              name: faq.question,
              acceptedAnswer: { '@type': 'Answer', text: faq.answer },
            })),
          },
        ]
      : []),
  ],
};
---

<MainLayout title={pageTitle} description={pageDescription} docket={docket} formNumber="DOSSIER">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <DocHero
    image="/images/protest.webp"
    imageAlt={`AARBAA ${country.name} international chapter road safety advocacy`}
    eager={true}
    ghost={country.code}
    kicker={`INTERNATIONAL LIAISON OFFICE — ${country.name.toUpperCase()} DESK · DOCKET NO. ${docket}`}
    title={`${country.name.toUpperCase()} LIAISON OFFICE`}
    classification={`LIAISON ACTIVE — ${country.capital.toUpperCase()} STATION`}
  />

  <nav class="crossref dossier-crossref" aria-label="Breadcrumb">
    <a href="/">HOME</a>
    <span aria-hidden="true">/</span>
    <a href="/countries">INTERNATIONAL</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">{country.name.toUpperCase()}</span>
  </nav>

  <nav class="tab-strip" aria-label="Dossier sections">
    <a href="#figures">FIGURES</a>
    <a href="#personnel">PERSONNEL</a>
    <a href="#outcomes">OUTCOMES</a>
    <a href="#proceedings">PROCEEDINGS</a>
    <a href="#case-files">CASE FILES</a>
    <a href="#inquiries">INQUIRIES</a>
    <a href="#records">RECORDS</a>
  </nav>

  <section id="figures" class="doc-section file-section" aria-labelledby="figures-head">
    <div class="section-head">
      <p class="kicker">QUARTERLY FIGURES · DOCKET NO. {docket}</p>
      <h2 id="figures-head">{country.name.toUpperCase()} ROAD SAFETY DATA</h2>
    </div>
    <StatLedger stats={deskStats} />

    {
      country.localStats && (
        <div class="figures-ledger">
          <div class="figures-ledger__row">
            <span class="figures-ledger__label">
              CYCLING FATALITIES ({country.localStats.cyclingFatalities.year})
            </span>
            <span class="leaders" aria-hidden="true" />
            <span class="figures-ledger__value">
              {country.localStats.cyclingFatalities.count.toLocaleString()}
            </span>
            <span class="badge-tag">{country.localStats.cyclingFatalities.change}</span>
          </div>
          <div class="figures-ledger__row">
            <span class="figures-ledger__label">INFRASTRUCTURE MILES — PROTECTED</span>
            <span class="leaders" aria-hidden="true" />
            <span class="figures-ledger__value">
              {country.localStats.infrastructureMiles.protected.toLocaleString()}
            </span>
          </div>
          <div class="figures-ledger__row">
            <span class="figures-ledger__label">INFRASTRUCTURE MILES — UNPROTECTED</span>
            <span class="leaders" aria-hidden="true" />
            <span class="figures-ledger__value">
              {country.localStats.infrastructureMiles.unprotected.toLocaleString()}
            </span>
          </div>
          <div class="figures-ledger__row">
            <span class="figures-ledger__label">INFRASTRUCTURE MILES — PLANNED</span>
            <span class="leaders" aria-hidden="true" />
            <span class="figures-ledger__value">
              {country.localStats.infrastructureMiles.planned.toLocaleString()}
            </span>
          </div>
          <div class="figures-ledger__row">
            <span class="figures-ledger__label">
              ROAD FUNDING SECURED — FISCAL YEAR {country.localStats.fundingSecured.year}
            </span>
            <span class="leaders" aria-hidden="true" />
            <span class="figures-ledger__value">
              {formatCurrency(
                country.localStats.fundingSecured.amount,
                country.localStats.fundingSecured.currency
              )}
            </span>
          </div>
        </div>
      )
    }

    {
      country.rating && (
        <p class="satisfaction-line">
          PUBLIC SATISFACTION INDEX: {country.rating.average.toFixed(1)} / 5 —{' '}
          {country.rating.count.toLocaleString()} RESPONSES ON FILE
        </p>
      )
    }
  </section>

  {
    country.regionalDirector && (
      <section id="personnel" class="doc-section file-section" aria-labelledby="personnel-head">
        <div class="section-head">
          <p class="kicker">PERSONNEL FILE · INTERNATIONAL LIAISON DIVISION</p>
          <h2 id="personnel-head">REGIONAL LEADERSHIP</h2>
        </div>
        <div class="personnel-card">
          <div class="personnel-card__row">
            <span class="personnel-card__label">OFFICER IN CHARGE</span>
            <span class="personnel-card__value">{country.regionalDirector.name}</span>
          </div>
          <div class="personnel-card__row">
            <span class="personnel-card__label">TITLE OF RECORD</span>
            <span class="personnel-card__value">{country.regionalDirector.title}</span>
          </div>
          <div class="personnel-card__row">
            <span class="personnel-card__label">ELECTRONIC MAIL</span>
            <span class="personnel-card__value">
              <a href={`mailto:${country.regionalDirector.email}`}>
                {country.regionalDirector.email}
              </a>
            </span>
          </div>
          <div class="personnel-card__row">
            <span class="personnel-card__label">TELEPHONE</span>
            <span class="personnel-card__value">{country.regionalDirector.phone}</span>
          </div>
        </div>
        <p class="doc-note">
          Leading AARBAA's advocacy efforts across {country.name}, coordinating{' '}
          {country.stats.chapters} regional chapters and representing the interests of{' '}
          {country.stats.members.toLocaleString()} members.
        </p>
      </section>
    )
  }

  {
    country.testimonials && country.testimonials.length > 0 && (
      <section class="doc-section file-section" aria-labelledby="comments-head">
        <div class="section-head">
          <p class="kicker">PUBLIC COMMENT RECORD · ENTERED WITHOUT OBJECTION</p>
          <h2 id="comments-head">VOICES FROM {country.name.toUpperCase()}</h2>
        </div>
        <CommentLedger
          entries={country.testimonials.map((t) => ({
            quote: t.quote,
            name: t.author,
            location: t.city,
          }))}
        />
      </section>
    )
  }

  {
    country.featuredArticle && (
      <section class="doc-section file-section" aria-labelledby="memo-head">
        <div class="section-head">
          <p class="kicker">FEATURED MEMORANDUM · RECORDS DIVISION</p>
          <h2 id="memo-head">LATEST FROM {country.name.toUpperCase()}</h2>
        </div>
        <article class="memo-abstract">
          <p class="memo-abstract__tag">FEATURED STORY</p>
          <h3 class="memo-abstract__title">{country.featuredArticle.title}</h3>
          <p class="memo-abstract__excerpt">{country.featuredArticle.excerpt}</p>
          <p class="memo-abstract__sep">FULL TEXT: FILED UNDER SEPARATE COVER</p>
        </article>
      </section>
    )
  }

  {
    country.victories && country.victories.length > 0 && (
      <section id="outcomes" class="doc-section file-section" aria-labelledby="outcomes-head">
        <div class="section-head">
          <p class="kicker">CASE OUTCOMES · CLOSED FILES</p>
          <h2 id="outcomes-head">OUR VICTORIES IN {country.name.toUpperCase()}</h2>
        </div>
        <div class="outcomes">
          {country.victories.slice(0, 3).map((victory, i) => (
            <article class="outcome">
              <div class="outcome__stamp">
                <Stamp text="RESOLVED" animated={i === 0} rotate={i === 0 ? -6 : i === 1 ? 3 : -3} />
              </div>
              <div class="outcome__meta">
                <span class="badge-tag">{victory.category.toUpperCase()}</span>
                <span class="outcome__date">{formatDate(victory.date)}</span>
                <span class="outcome__location">{victory.location.toUpperCase()}</span>
              </div>
              <h3 class="outcome__title">{victory.title}</h3>
              <p class="outcome__desc">{victory.description}</p>
              <div class="outcome__impact">
                <span class="outcome__impact-label">IMPACT:</span>
                <p>{victory.impact}</p>
              </div>
            </article>
          ))}
        </div>
        {extraOutcomes > 0 && <p class="doc-more">+{extraOutcomes} ADDITIONAL OUTCOMES ON FILE</p>}
      </section>
    )
  }

  {
    country.upcomingEvents && country.upcomingEvents.length > 0 && (
      <section
        id="proceedings"
        class="doc-section file-section"
        aria-labelledby="proceedings-head"
      >
        <div class="section-head">
          <p class="kicker">SCHEDULED PROCEEDINGS · PUBLIC NOTICE</p>
          <h2 id="proceedings-head">UPCOMING EVENTS</h2>
        </div>
        <div class="proceedings">
          {country.upcomingEvents.map((event) => {
            const concluded = new Date(event.date) < now;
            return (
              <article class="proceeding">
                <div class="proceeding__meta">
                  <p>
                    <span class="proceeding__label">DATE</span>
                    {formatDateRange(event.date, event.endDate).toUpperCase()}
                  </p>
                  <p>
                    <span class="proceeding__label">TIME</span>
                    {event.time}
                  </p>
                  <p>
                    <span class="proceeding__label">VENUE</span>
                    {event.venue}
                  </p>
                  <p>
                    <span class="proceeding__label">ADDRESS</span>
                    {event.address}, {event.city}
                  </p>
                </div>
                <div class="proceeding__body">
                  <div class="proceeding__head">
                    <h3>{event.name}</h3>
                    <span class="badge-tag">{event.eventType.toUpperCase()}</span>
                  </div>
                  <p class="proceeding__desc">{event.description}</p>
                  {concluded ? (
                    <p class="proceeding__note">PROCEEDINGS CONCLUDED — MINUTES ON FILE</p>
                  ) : event.registrationRequired ? (
                    <p class="proceeding__note">REGISTRATION REQUIRED — FORM AAR-101</p>
                  ) : null}
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )
  }

  {
    country.infrastructureIssues && country.infrastructureIssues.length > 0 && (
      <section id="case-files" class="doc-section file-section" aria-labelledby="cases-head">
        <div class="section-head">
          <p class="kicker">INFRASTRUCTURE CASE FILES · OPEN MATTERS</p>
          <h2 id="cases-head">INFRASTRUCTURE ISSUES WE'RE ADDRESSING</h2>
        </div>
        <div class="case-files">
          {country.infrastructureIssues.map((issue) => (
            <article class="case-file">
              <div class="case-file__tags">
                <span class="badge-tag">{issue.severity.toUpperCase()} PRIORITY</span>
                <span class="badge-tag">{issue.status.replace('-', ' ').toUpperCase()}</span>
              </div>
              <h3 class="case-file__title">{issue.title}</h3>
              <p class="case-file__desc">{issue.description}</p>
              <dl class="case-file__details">
                <div>
                  <dt>LOCATION</dt>
                  <dd>{issue.location}</dd>
                </div>
                <div>
                  <dt>AFFECTED AREAS</dt>
                  <dd>{issue.affectedCities.join(', ')}</dd>
                </div>
                <div>
                  <dt>PROPOSED SOLUTION</dt>
                  <dd>{issue.proposedSolution}</dd>
                </div>
                <div>
                  <dt>LAST UPDATED</dt>
                  <dd>{formatDate(issue.lastUpdated)}</dd>
                </div>
              </dl>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    country.faqs && country.faqs.length > 0 && (
      <section id="inquiries" class="doc-section file-section" aria-labelledby="inquiries-head">
        <div class="section-head">
          <p class="kicker">PUBLIC COUNTER · RESPONSES PREPARED IN ADVANCE</p>
          <h2 id="inquiries-head">FREQUENTLY FILED INQUIRIES</h2>
        </div>
        <div class="inquiries">
          {country.faqs.map((faq, i) => (
            <details class="details-folder" open={i === 0}>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )
  }

  <section id="records" class="doc-section file-section" aria-labelledby="records-head">
    <div class="section-head">
      <p class="kicker">PHOTOGRAPHIC RECORDS · EVIDENCE LOCKER</p>
      <h2 id="records-head">PHOTO GALLERY</h2>
    </div>
    <PendingRecords docket={docket} count={4} />
  </section>

  <section class="doc-section file-section" aria-labelledby="join-head">
    <div class="section-head">
      <p class="kicker">FILE A REQUEST · FORM AAR-101</p>
      <h2 id="join-head">JOIN AARBAA {country.name.toUpperCase()}</h2>
    </div>
    <p class="doc-copy">
      Be part of our growing movement of {country.stats.members.toLocaleString()} members across
      {country.stats.chapters} chapters in {country.name}. Together, we're advocating for balanced
      transportation policy and motorists' rights.
    </p>
    <p class="routing-hint">
      INTERNATIONAL CORRESPONDENCE IS ROUTED VIA THE NEAREST U.S. FIELD OFFICE
    </p>
    <ContactForm formNumber="AAR-101" />
  </section>

  <section class="doc-section file-section" aria-labelledby="xref-head">
    <div class="section-head">
      <p class="kicker">CROSS-REFERENCES · RECORDS RETENTION SCHEDULE 7</p>
      <h2 id="xref-head">ADDITIONAL RESOURCES</h2>
    </div>
    <ul class="xref-list">
      <li><a class="crossref" href="/news">SEE: OFFICIAL RECORDS — MEMORANDA LOG — /news</a></li>
      <li>
        <a class="crossref" href="/chapters">
          SEE: DIRECTORY OF FIELD OFFICES (US) — /chapters
        </a>
      </li>
      <li>
        <a class="crossref" href="/countries">
          SEE: INTERNATIONAL LIAISON OFFICES — /countries
        </a>
      </li>
    </ul>
  </section>
</MainLayout>

<style>
  .dossier-crossref {
    margin: var(--s4) 0 var(--s3);
  }

  .tab-strip {
    margin-bottom: var(--s3);
  }

  .doc-section {
    position: relative;
    padding: var(--s6) 0;
    border-top: 1px solid var(--rule);
    scroll-margin-top: var(--s6);
  }

  .doc-section:first-of-type {
    border-top: 0;
  }

  .section-head {
    margin-bottom: var(--s4);
  }

  .figures-ledger {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s2) var(--s4);
    margin-top: var(--s4);
  }

  .figures-ledger__row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s2);
    padding: var(--s3) 0;
    border-bottom: 1px solid var(--rule);
  }

  .figures-ledger__row:last-child {
    border-bottom: 0;
  }

  .figures-ledger__label {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
  }

  .figures-ledger__value {
    font-family: var(--font-display);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-lg);
    letter-spacing: 0.04em;
  }

  .satisfaction-line {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin-top: var(--s4);
  }

  .personnel-card {
    border: 2px solid var(--ink);
    background: var(--paper-raised);
    max-width: 760px;
  }

  .personnel-card__row {
    display: grid;
    grid-template-columns: 220px 1fr;
    border-bottom: 1px solid var(--rule);
  }

  .personnel-card__row:last-child {
    border-bottom: 0;
  }

  .personnel-card__label {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    padding: var(--s3);
    border-right: 1px solid var(--rule);
  }

  .personnel-card__value {
    padding: var(--s3);
    overflow-wrap: anywhere;
  }

  .personnel-card__value a {
    color: var(--glory-red);
  }

  .doc-note {
    margin-top: var(--s4);
    max-width: var(--measure);
  }

  .memo-abstract {
    border: 1px solid var(--ink);
    background: var(--paper-raised);
    box-shadow: var(--shadow-sheet);
    padding: var(--s5);
    max-width: 760px;
  }

  .memo-abstract__tag {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    color: var(--glory-red);
    margin-bottom: var(--s2);
  }

  .memo-abstract__title {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--fs-xl);
    line-height: 1.15;
    margin-bottom: var(--s3);
  }

  .memo-abstract__excerpt {
    max-width: var(--measure);
    margin-bottom: var(--s4);
  }

  .memo-abstract__sep {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    border-top: 1px dashed var(--rule);
    padding-top: var(--s3);
  }

  .outcomes {
    display: grid;
    gap: var(--s4);
  }

  .outcome {
    position: relative;
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s5);
    padding-right: calc(var(--s5) + 8rem);
  }

  .outcome__stamp {
    position: absolute;
    top: var(--s3);
    right: var(--s3);
  }

  .outcome__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--s3);
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin-bottom: var(--s3);
  }

  .outcome__title {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--fs-lg);
    line-height: 1.15;
    margin-bottom: var(--s3);
  }

  .outcome__desc {
    max-width: var(--measure);
    margin-bottom: var(--s4);
  }

  .outcome__impact {
    border-left: 3px solid var(--glory-red);
    padding: var(--s2) var(--s3);
  }

  .outcome__impact-label {
    display: block;
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--glory-red);
    margin-bottom: var(--s1);
  }

  .outcome__impact p {
    font-size: var(--fs-sm);
    max-width: var(--measure);
  }

  .doc-more {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    letter-spacing: 0.08em;
    margin-top: var(--s4);
  }

  .proceedings {
    display: grid;
    gap: var(--s4);
  }

  .proceeding {
    display: grid;
    grid-template-columns: 280px 1fr;
    border: 1px solid var(--rule);
    background: var(--paper);
  }

  .proceeding__meta {
    display: grid;
    gap: var(--s3);
    align-content: start;
    padding: var(--s4);
    border-right: 1px solid var(--rule);
    font-family: var(--font-type);
    font-size: var(--fs-sm);
  }

  .proceeding__label {
    display: block;
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    margin-bottom: var(--s1);
  }

  .proceeding__body {
    padding: var(--s4);
  }

  .proceeding__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
