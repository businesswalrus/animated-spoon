---
import MainLayout from '../../layouts/MainLayout.astro';
import DocHero from '../../components/DocHero.astro';
import StatLedger from '../../components/StatLedger.astro';
import Stamp from '../../components/Stamp.astro';
import { getAllCountries } from '../../data/countries';

const pageTitle = 'International Liaison Offices — AARBAA';
const pageDescription =
  "AARBAA is a global movement advocating for balanced road safety policy. With chapters in 5 countries and growing, we represent motorists' interests worldwide.";

const countries = getAllCountries();
const sortedCountries = [...countries].sort((a, b) => a.name.localeCompare(b.name));

// Aggregate figures compiled from all liaison desks.
const totalMembers = countries.reduce((sum, country) => sum + country.stats.members, 0);
const totalChapters = countries.reduce((sum, country) => sum + country.stats.chapters, 0);
const totalVictories = countries.reduce((sum, country) => sum + country.stats.victories, 0);

const liaisonStats = [
  { value: totalMembers.toLocaleString(), label: 'INTERNATIONAL MEMBERS' },
  { value: totalChapters.toLocaleString(), label: 'REGIONAL CHAPTERS' },
  { value: totalVictories.toLocaleString(), label: 'INTERNATIONAL VICTORIES' },
];

// Regional highlights — copy ported verbatim from the previous international index.
const deskNotes = [
  {
    name: 'United Kingdom',
    note: 'Fighting against excessive cycle lane expansion in London and major cities',
  },
  {
    name: 'Canada',
    note: 'Advocating for seasonal cycling infrastructure in harsh winter climates',
  },
  {
    name: 'Australia',
    note: 'Challenging unfair minimum passing distance laws on rural roads',
  },
  {
    name: 'Germany',
    note: 'Protecting Autobahn freedom and opposing Green Party speed limits',
  },
];
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  docket="AAR-INTL · LIAISON DIVISION"
  formNumber="DIRECTORY"
>
  <DocHero
    image="/images/protest.webp"
    imageAlt="AARBAA members assembled at a public demonstration for road fairness"
    kicker="INTERNATIONAL LIAISON DIVISION"
    title="INTERNATIONAL LIAISON OFFICES"
    subtitle="A Global Movement for Motorists' Rights and Balanced Transportation Policy"
    classification={`${countries.length} DESKS REPORTING`}
  />

  <section class="doc-section file-section" aria-labelledby="impact-head">
    <div class="section-head">
      <p class="kicker">QUARTERLY FIGURES · CONSOLIDATED RETURNS</p>
      <h2 id="impact-head">OUR GLOBAL IMPACT</h2>
    </div>
    <StatLedger stats={liaisonStats} />
  </section>

  <section class="doc-section file-section" aria-labelledby="mission-head">
    <div class="section-head">
      <p class="kicker">STATEMENT OF PURPOSE · ENTERED INTO THE RECORD</p>
      <h2 id="mission-head">WHY AARBAA INTERNATIONAL?</h2>
    </div>
    <div class="charter-box">
      <p>
        From London to Sydney, Toronto to Berlin, the same pattern repeats: urban planners
        prioritize cycling infrastructure at the expense of motorists who make up the vast majority
        of road users. AARBAA International coordinates advocacy efforts across nations, sharing
        strategies and amplifying our collective voice.
      </p>
      <p>
        We're not anti-cycling—we're pro-balance. We advocate for transportation policy that serves
        all citizens, not just the vocal minority.
      </p>
    </div>
  </section>

  <section class="doc-section file-section" aria-labelledby="registry-head">
    <div class="registry-stamp">
      <Stamp text="RECEIVED" rotate={-6} />
    </div>
    <div class="section-head">
      <p class="kicker">REGISTRY OF DESKS · ALPHABETICAL BY NATION</p>
      <h2 id="registry-head">OUR INTERNATIONAL CHAPTERS</h2>
    </div>
    <div class="registry">
      {
        sortedCountries.map((country) => (
          <a class="registry__row" href={`/countries/${country.slug}/`}>
            <span class="registry__no">{`AAR-INTL-${country.code}`}</span>
            <span class="registry__subject">{country.name}</span>
            <span class="leaders" aria-hidden="true"></span>
            <span class="registry__abstract">
              {country.stats.members.toLocaleString()} MEMBERS · {country.stats.chapters}{' '}
              {country.stats.chapters === 1 ? 'CHAPTER' : 'CHAPTERS'}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="doc-section file-section" aria-labelledby="highlights-head">
    <div class="section-head">
      <p class="kicker">DESK NOTES · SUMMARY OF ACTIVE MATTERS</p>
      <h2 id="highlights-head">REGIONAL HIGHLIGHTS</h2>
    </div>
    <div class="desk-notes">
      {
        deskNotes.map((desk) => (
          <div class="desk-notes__row">
            <span class="desk-notes__name">{desk.name.toUpperCase()}</span>
            <span class="leaders" aria-hidden="true"></span>
            <span class="desk-notes__note">{desk.note}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="doc-section file-section" aria-labelledby="us-head">
    <div class="section-head">
      <p class="kicker">DOMESTIC CROSS-REFERENCE · FIELD OPERATIONS DIVISION</p>
      <h2 id="us-head">LOOKING FOR US CHAPTERS?</h2>
    </div>
    <p class="doc-copy">
      AARBAA was founded in the United States and maintains active chapters in all 50 states. With
      over 15,000 members nationwide, our US operations are the largest and most established part
      of our organization.
    </p>
    <div class="doc-actions">
      <a href="/chapters/" class="btn btn--primary">VIEW US STATE CHAPTERS</a>
    </div>
  </section>

  <section class="doc-section file-section" aria-labelledby="expand-head">
    <div class="section-head">
      <p class="kicker">NEW DESK REQUESTS · PUBLIC COUNTER</p>
      <h2 id="expand-head">DON'T SEE YOUR COUNTRY?</h2>
    </div>
    <p class="doc-copy">
      AARBAA International is expanding globally. If your country isn't listed yet, help us bring
      balanced transportation advocacy to your nation. We provide resources, templates, and support
      for new international chapters.
    </p>
    <div class="doc-actions">
      <a href="/contact/" class="btn btn--primary">START AN INTERNATIONAL CHAPTER</a>
      <a href="/about/" class="btn">LEARN MORE ABOUT AARBAA</a>
    </div>
  </section>
</MainLayout>

<style>
  .doc-section {
    position: relative;
    padding: var(--s6) 0;
    border-top: 1px solid var(--rule);
  }

  .doc-section:first-of-type {
    border-top: 0;
  }

  .section-head {
    margin-bottom: var(--s5);
  }

  .registry-stamp {
    position: absolute;
    top: var(--s4);
    right: var(--s2);
    z-index: 2;
  }

  .charter-box {
    border: 1px solid var(--ink);
    outline: 1px solid var(--rule);
    outline-offset: 4px;
    background: var(--paper-raised);
    padding: var(--s5);
    max-width: 820px;
  }

  .charter-box p {
    max-width: var(--measure);
    font-size: var(--fs-md);
    line-height: 1.8;
  }

  .charter-box p + p {
    margin-top: var(--s4);
  }

  .desk-notes {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s2) var(--s4);
  }

  .desk-notes__row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s2);
    padding: var(--s3) 0;
    border-bottom: 1px solid var(--rule);
  }

  .desk-notes__row:last-child {
    border-bottom: 0;
  }

  .desk-notes__name {
    font-family: var(--font-type);
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .desk-notes__note {
    color: var(--ink-soft);
    font-size: var(--fs-sm);
    max-width: 44ch;
  }

  .doc-copy {
    max-width: var(--measure);
    font-size: var(--fs-md);
    line-height: 1.8;
    margin-bottom: var(--s4);
  }

  .doc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s3);
  }

  @media (max-width: 720px) {
    .doc-section {
      padding: var(--s5) 0;
    }

    .registry-stamp {
      position: static;
      margin-bottom: var(--s3);
    }
  }
</style>
