---
// src/pages/index.astro — FORM AAR-000 · THE BUREAU'S PUBLIC PORTAL
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import DocHero from '../components/DocHero.astro';
import StatLedger from '../components/StatLedger.astro';
import CommentLedger from '../components/CommentLedger.astro';
import ContactForm from '../components/ContactForm.astro';
import Figure from '../components/Figure.astro';
import Stamp from '../components/Stamp.astro';
import Icon from '../components/Icon.astro';
import { stats } from '../data/stats';
import { testimonials } from '../data/testimonials';

const metaDescription =
  "AARBAA fights for safer roads by advocating for separate bike paths. Join 15,000+ members demanding cyclist accountability and better infrastructure for everyone.";

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AARBAA - Americans Against Road Bikers Association of America',
  alternateName: 'AARBAA',
  url: 'https://aarbaa.com',
  logo: 'https://aarbaa.com/images/aarbaa-logo.svg',
  foundingDate: '2023',
};

// The Ten Key Concerns, codified. Copy ports verbatim from the prior filing.
const concerns = [
  {
    num: '1.01',
    title: 'Road sharing "challenges"',
    body: 'Some drivers find it frustrating when cyclists occupy vehicle lanes, especially on narrow roads where passing safely is difficult.',
  },
  {
    num: '1.02',
    title: 'Traffic flow disruption',
    body: 'Cyclists typically move slower than vehicular traffic, which can create congestion in areas without proper bike infrastructure.',
  },
  {
    num: '1.03',
    title: 'Perceived rule-breaking',
    body: "There's a perception that some cyclists ignore traffic laws, like running stop signs or red lights, creating safety hazards.",
  },
  {
    num: '1.04',
    title: 'Infrastructure costs',
    body: 'Building dedicated cycling infrastructure requires public funding that some taxpayers may prefer allocated elsewhere.',
  },
  {
    num: '1.05',
    title: 'Rural road limitations',
    body: 'Many rural roads lack shoulders or bike lanes, creating potentially dangerous situations when cyclists and vehicles share these roads.',
  },
  {
    num: '1.06',
    title: 'Licensing and regulation differences',
    body: "Unlike motorists, cyclists typically don't require licenses or registration, which some view as regulatory inconsistency.",
  },
  {
    num: '1.07',
    title: 'Cultural tensions',
    body: 'In some communities, tensions exist between drivers and cyclists about road use rights.',
  },
  {
    num: '1.08',
    title: 'Seasonal challenges',
    body: 'In areas with harsh winters or extreme weather, cycling infrastructure may go unused for significant portions of the year.',
  },
  {
    num: '1.09',
    title: 'Parking conflicts',
    body: 'Bike racks and storage can sometimes take up space in urban areas where parking is already limited.',
  },
  {
    num: '1.10',
    title: 'Emergency vehicle considerations',
    body: 'On narrow roads, groups of cyclists might make it challenging for emergency vehicles to pass quickly.',
  },
] as const;

const battlegrounds = [
  {
    icon: 'road-sign',
    title: 'ROAD HOGGING 101',
    content:
      "Fighting to banish lycra-clad road blockers to their own designated lanes where they can pretend they're Lance Armstrong without endangering the rest of us.",
  },
  {
    icon: 'gavel',
    title: 'SAFETY REALITY CHECK',
    content:
      "Demanding cyclists actually become visible with more than just their neon outfits and fragile egos—let's make reflectors, helmets, and accountability mandatory.",
  },
  {
    icon: 'document',
    title: 'RULES ARE FOR EVERYONE',
    content:
      'Funding programs to remind the bike brigade that red lights and stop signs apply to THEM TOO—shocking, we know.',
  },
  {
    icon: 'sedan',
    title: 'FAIRNESS FOR THE 99%',
    content:
      "Balancing the scales of justice so one cyclist's 'right to the road' doesn't trump fifty drivers' right to get to work on time without having a collective aneurysm.",
  },
] as const;

const ledgerStats = stats.map((s) => ({ value: s.number, label: s.label }));
const commentEntries = testimonials.map(({ quote, name, location }) => ({ quote, name, location }));

const featuredIds = ['spitting-epidemic', 'great-spandex-census', 'bill-477-update'];
const latest = (await getCollection('news'))
  .filter((entry) => featuredIds.includes(entry.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date
    .toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })
    .toUpperCase();
---

<MainLayout
  title="AARBAA - Americans Against Road Bikers | Road Safety Advocacy"
  description={metaDescription}
  docket="AAR-000 · PUBLIC PORTAL"
  formNumber="FORM AAR-000"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </Fragment>

  <!-- ============ HERO — PUBLIC PORTAL COVER SHEET ============ -->
  <div class="home-hero">
    <DocHero
      title="Because America Has Had Enough"
      kicker="THE BUREAU OF ROAD FAIRNESS — PUBLIC PORTAL"
      classification="OFFICE OF PUBLIC AWARENESS — RELEASE AUTHORIZED"
      image="/images/protest.webp"
      imageAlt="AARBAA members holding signs at a public road-safety demonstration"
      eager={true}
      poster={true}
    >
      <p class="home-hero__sub">
        <span class="redact">Americans Against Road Bikers</span>
        <span class="redact">Association of America</span>
      </p>
      <div class="home-hero__cta">
        <a class="btn btn--primary" href="/join">Join Our Cause</a>
        <a class="btn" href="#issues">Review the Issues</a>
      </div>
    </DocHero>
  </div>

  <!-- ============ SEC. 1 — THE ISSUES (FOLDER TABS) ============ -->
  <section id="issues" class="file-section" aria-labelledby="issues-heading">
    <header class="section-head">
      <p class="kicker">SEC. 1 — STATEMENT OF GRIEVANCES</p>
      <h2 id="issues-heading">THE ISSUES</h2>
    </header>

    <div class="tab-strip issues-tabs">
      <input class="tab-strip__radio" type="radio" name="issues-tab" id="tab-problem" checked />
      <input class="tab-strip__radio" type="radio" name="issues-tab" id="tab-concerns" />
      <input class="tab-strip__radio" type="radio" name="issues-tab" id="tab-approach" />

      <div class="tab-strip__tabs">
        <label class="tab-strip__tab" for="tab-problem">The Problem</label>
        <label class="tab-strip__tab" for="tab-concerns">10 Key Concerns</label>
        <label class="tab-strip__tab" for="tab-approach">Our Approach</label>
      </div>

      <!-- FOLDER 1 OF 3 — THE PROBLEM -->
      <div class="tab-strip__panel" id="panel-problem">
        <p class="attention-heading" aria-label="You've seen them. We've all seen them.">
          YOU'VE SEEN THEM.<br />WE'VE ALL SEEN THEM.
        </p>

        <div class="prose">
          <p>
            Those packs of neon-clad warriors, squeezing into tight formations on our precious roadways,
            pedaling with the self-importance of someone who thinks they're saving the planet one
            insufferable mile at a time.
          </p>
          <p>
            Let's be honest about road bikers, shall we? These weekend warriors aren't environmental heroes
            – they're just hobbyists with expensive toys clogging up our roads. The irony of watching
            someone load a $5,000 carbon fiber bike onto a gas-guzzling SUV before driving 40 minutes to
            their cycling route isn't lost on the rest of us sitting in traffic behind them.
          </p>
          <p>
            "Share the road," they preach, while taking up entire lanes during rush hour. Nothing says "I
            respect others" quite like forcing a line of 20 cars to crawl at 12 mph around blind corners
            because heaven forbid they use the bike path built specifically for this purpose.
          </p>
          <p>
            And let's talk safety – not just theirs, but ours too. When a cyclist decides that stop signs
            are merely suggestions, guess who's legally responsible when things go sideways? That's right –
            the driver with actual insurance and a license plate.
          </p>
          <p>
            Cyclists often claim the moral high ground, but their actions on the road tell a different
            story. It's time to hold them accountable and demand real solutions that work for everyone.
          </p>
        </div>
      </div>

      <!-- FOLDER 2 OF 3 — TEN KEY CONCERNS, CODIFIED § 1.01–1.10 -->
      <div class="tab-strip__panel" id="panel-concerns">
        <p class="statute-note">TITLE 1 — ENUMERATED CONCERNS OF THE MOTORING PUBLIC</p>
        <ol class="statute-list">
          {
            concerns.map((c, i) => (
              <li class="statute">
                <span class="ghost statute__ghost" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <h3 class="statute__title">§ {c.num} — {c.title}</h3>
                <p class="statute__body">{c.body}</p>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- FOLDER 3 OF 3 — OUR APPROACH -->
      <div class="tab-strip__panel" id="panel-approach">
        <div class="approach">
          <div class="prose approach__text">
            <p>
              We're not just complaining—we're taking action! Founded in 2023 by drivers who've had
              <span class="highlight">ENOUGH</span>, Americans Against Road Bikers stands up for the
              forgotten majority: the people who actually pay road taxes.
            </p>
            <p>
              While the spandex brigade clogs our streets without contributing a dime to infrastructure,
              we're fighting for transportation policies that reflect <span class="highlight">REALITY</span>,
              not cyclist fantasy land. We advocate for dedicated bike paths separate from main roads -
              because safety matters for everyone.
            </p>
            <p>
              Yes, we believe in "sharing the road"—in a way that makes sense. That means cyclists should
              have their own infrastructure instead of pretending they're training for the Tour de France
              on your morning commute. Our common-sense approach demands accountability from
              <span class="highlight">BOTH</span> sides.
            </p>
            <p>
              When planning communities, we need to recognize the reality: cars, bikes, and pedestrians
              deserve separate spaces to maximize safety and efficiency for everyone.
            </p>
          </div>
          <div class="approach__figure">
            <Figure
              src="/images/Citycouncil.webp"
              alt="AARBAA members advocating for road safety at community meeting"
              num="1"
              caption="MEMBERS ADVOCATING FOR ROAD SAFETY AT A COMMUNITY MEETING"
              source="OFFICE OF PUBLIC AWARENESS"
              tilt="right"
              width={681}
              height={383}
            />
          </div>
        </div>
      </div>
    </div>

    <div class="section-cta">
      <a class="btn btn--primary" href="#join">JOIN THE MOVEMENT</a>
    </div>
  </section>

  <!-- ============ SEC. 2 — KEY BATTLEGROUNDS ============ -->
  <section id="battlegrounds" class="file-section" aria-labelledby="battlegrounds-heading">
    <header class="section-head">
      <p class="kicker">SEC. 2 — ACTIVE MATTERS BEFORE THE BUREAU</p>
      <h2 id="battlegrounds-heading">KEY BATTLEGROUNDS</h2>
    </header>
    <p class="section-lead">The four horsemen of the cycling apocalypse we're fighting every day</p>

    <div class="matters">
      {
        battlegrounds.map((b, i) => (
          <article class="matter">
            <div class="matter__head">
              <Icon name={b.icon} size={26} />
              <span class="matter__no">MATTER {String(i + 1).padStart(2, '0')} OF 04</span>
            </div>
            <h3 class="matter__title">{b.title}</h3>
            <p class="matter__body">{b.content}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ============ SEC. 3 — QUARTERLY FIGURES ============ -->
  <section id="stats" class="file-section" aria-labelledby="stats-heading">
    <header class="section-head">
      <p class="kicker">SEC. 3 — REPORTING PERIOD ENDING 06/30/2026</p>
      <h2 id="stats-heading">THE NUMBERS DON'T LIE</h2>
    </header>
    <StatLedger title="QUARTERLY FIGURES" stats={ledgerStats} />
  </section>

  <!-- ============ SEC. 4 — LATEST UPDATES (MEMORANDA LOG) ============ -->
  <section id="news" class="file-section" aria-labelledby="news-heading">
    <header class="section-head">
      <p class="kicker">SEC. 4 — RECORDS DIVISION · MEMORANDA LOG</p>
      <h2 id="news-heading">LATEST UPDATES</h2>
    </header>
    <p class="section-lead">Stay informed about our crusade against road bikers</p>

    <div class="registry">
      {
        latest.map((entry) => (
          <article class="registry__row">
            <p class="registry__no">{entry.data.memoNo} · {formatDate(entry.data.date)}</p>
            <h3 class="registry__subject">
              <a href={`/news/${entry.id}`}>{entry.data.title}</a>
            </h3>
            <p class="registry__abstract">{entry.data.excerpt}</p>
          </article>
        ))
      }
    </div>

    <!-- CASE OUTCOME ON FILE — OAK STREET -->
    <aside class="victory-memo" aria-labelledby="victory-heading">
      <div class="victory-memo__stamp">
        <Stamp text="APPROVED 7–2" rotate={-6} />
      </div>
      <p class="victory-memo__no">MEMO 2025-0318-A · MARCH 18, 2025 · DISPOSITION: FAVORABLE</p>
      <h3 id="victory-heading" class="victory-memo__title">
        <a href="/news/oak-street-victory">VICTORY AT OAK STREET</a>
      </h3>
      <p class="victory-memo__body">
        500 patriots saved their parking spaces and defeated a $3.2 million bike lane boondoggle. Democracy
        wins, cyclists lose...
      </p>
      <a class="crossref" href="/news/oak-street-victory">CROSS-REF: FULL MEMORANDUM ON FILE</a>
    </aside>

    <div class="section-cta">
      <a class="btn" href="/news">View All Updates</a>
    </div>
  </section>

  <!-- ============ SEC. 5 — PUBLIC COMMENT RECORD ============ -->
  <section id="testimonials" class="file-section" aria-labelledby="testimonials-heading">
    <header class="section-head">
      <p class="kicker">SEC. 5 — COMMENTS ENTERED INTO THE RECORD</p>
      <h2 id="testimonials-heading">VOICES FROM THE TRENCHES</h2>
    </header>
    <p class="section-lead">Real Americans who have joined our movement</p>

    <CommentLedger entries={commentEntries} />
  </section>

  <!-- ============ SEC. 6 — APPLICATION FOR ENROLLMENT ============ -->
  <section id="join" class="file-section" aria-labelledby="join-heading">
    <header class="section-head">
      <p class="kicker">FORM AAR-100 — APPLICATION FOR ENROLLMENT</p>
      <h2 id="join-heading">JOIN THE RESISTANCE</h2>
    </header>
    <p class="section-lead">
      Become a member today and help us reclaim America's roads one bike path at a time!
    </p>

    <div class="enroll-panel">
      <ContactForm formNumber="AAR-100-A" heading="PRELIMINARY INTAKE" />
      <p class="enroll-panel__ref">
        <a class="crossref" href="/join">CROSS-REF: FORM AAR-100 — FULL APPLICATION, FEE SCHEDULE, AND MEMBER PRIVILEGES</a>
      </p>
    </div>
  </section>

  <!-- ============ SEC. 7 — PUBLIC COUNTER ============ -->
  <section id="contact" class="file-section" aria-labelledby="contact-heading">
    <header class="section-head">
      <p class="kicker">SEC. 7 — REQUESTS FOR ASSISTANCE</p>
      <h2 id="contact-heading">GET IN TOUCH</h2>
    </header>
    <p class="section-lead">Have questions or want to report a cyclist incident? We're here to help!</p>
    <div class="section-cta section-cta--tight">
      <a class="btn btn--primary" href="/contact">Contact Us</a>
    </div>
  </section>
</MainLayout>

<style>
  /* ---- HERO (poster scale via DocHero's poster prop, home only) ---- */
  .home-hero__sub {
    margin: var(--s3) 0 0;
    font-family: var(--font-type);
    font-size: var(--fs-md);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s2);
  }

  .home-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s3);
    margin-top: var(--s4);
  }

  /* ---- Section furniture (arrangement only) ---- */
  .file-section {
    padding: var(--s6) 0;
    border-bottom: 1px solid var(--rule);
  }

  .file-section:last-of-type {
    border-bottom: 0;
  }

  .section-lead {
    max-width: var(--measure);
    color: var(--ink-soft);
    font-size: var(--fs-md);
    margin: var(--s3) 0 var(--s4);
  }

  .section-cta {
    text-align: center;
    margin-top: var(--s5);
  }

  .section-cta--tight {
    margin-top: var(--s4);
    text-align: left;
  }

  /* ---- Folder tabs: functional wiring for this page's three panes.
         Visual folder chrome comes from the global .tab-strip pattern;
         these ID-scoped rules only bind checked-state to panels. ---- */
  .issues-tabs {
    margin-top: var(--s4);
  }

  .tab-strip__radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .tab-strip__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s1);
    align-items: flex-end;
  }

  .tab-strip__tab {
    font-family: var(--font-type);
    font-weight: 700;
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--s2) var(--s4);
    border: 1px solid var(--rule);
    border-bottom: 0;
    background: var(--paper);
    color: var(--ink-soft);
    cursor: pointer;
  }

  .tab-strip__panel {
    display: none;
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: var(--s5) var(--s4);
  }

  #tab-problem:checked ~ #panel-problem,
  #tab-concerns:checked ~ #panel-concerns,
  #tab-approach:checked ~ #panel-approach {
    display: block;
  }

  #tab-problem:checked ~ .tab-strip__tabs .tab-strip__tab[for='tab-problem'],
  #tab-concerns:checked ~ .tab-strip__tabs .tab-strip__tab[for='tab-concerns'],
  #tab-approach:checked ~ .tab-strip__tabs .tab-strip__tab[for='tab-approach'] {
    background: var(--paper-raised);
    color: var(--ink);
    border-color: var(--ink);
    position: relative;
    top: 1px;
  }

  #tab-problem:focus-visible ~ .tab-strip__tabs .tab-strip__tab[for='tab-problem'],
  #tab-concerns:focus-visible ~ .tab-strip__tabs .tab-strip__tab[for='tab-concerns'],
  #tab-approach:focus-visible ~ .tab-strip__tabs .tab-strip__tab[for='tab-approach'] {
    outline: 2px solid var(--glory-red);
    outline-offset: 2px;
  }

  /* ---- Pane 1: the problem ---- */
  .attention-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.15;
    color: var(--glory-red);
    border-bottom: 5px solid var(--glory-red);
    display: inline-block;
    padding-bottom: var(--s2);
    margin: 0 0 var(--s4);
  }

  /* ---- Pane 2: statute list with ghost numerals ---- */
  .statute-note {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin: 0 0 var(--s4);
  }

  .statute-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .statute {
    position: relative;
    overflow: hidden;
    padding: var(--s4) var(--s3) var(--s4) 0;
    border-top: 1px dotted var(--rule);
  }

  .statute:first-child {
    border-top: 0;
  }

  .statute__ghost {
    position: absolute;
    right: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 8.5rem;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .statute__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-lg);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 var(--s2);
    position: relative;
  }

  .statute__body {
    max-width: var(--measure);
    color: var(--ink-soft);
    margin: 0;
    position: relative;
  }

  /* ---- Pane 3: approach ---- */
  .approach {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
    gap: var(--s5);
    align-items: start;
  }

  .highlight {
    color: var(--glory-red);
    font-weight: 700;
  }

  /* ---- Battlegrounds: memo abstracts ---- */
  .matters {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--s4);
  }

  .matter {
    border-top: 3px solid var(--ink);
    background: var(--paper);
    padding: var(--s3) var(--s3) var(--s4);
  }

  .matter__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s2);
    color: var(--glory-blue);
    margin-bottom: var(--s3);
  }

  .matter__no {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
  }

  .matter__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-xl);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 var(--s2);
  }

  .matter__body {
    color: var(--ink-soft);
    margin: 0;
  }

  /* ---- Oak Street victory memo ---- */
  .victory-memo {
    position: relative;
    margin-top: var(--s5);
    border: 1px solid var(--rule);
    border-left: 5px solid var(--glory-red);
    background: var(--paper);
    padding: var(--s4) var(--s5) var(--s4) var(--s4);
  }

  .victory-memo__stamp {
    position: absolute;
    top: -1.25rem;
    right: var(--s4);
    z-index: 2;
  }

  .victory-memo__no {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin: 0 0 var(--s2);
  }

  .victory-memo__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-2xl);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 var(--s2);
  }

  .victory-memo__title a {
    color: var(--ink);
    text-decoration: none;
  }

  .victory-memo__title a:hover,
  .victory-memo__title a:focus-visible {
    color: var(--glory-red);
    text-decoration: underline;
  }

  .victory-memo__body {
    max-width: var(--measure);
    color: var(--ink-soft);
    margin: 0 0 var(--s3);
  }

  /* ---- Enrollment panel ---- */
  .enroll-panel {
    max-width: 46rem;
  }

  .enroll-panel__ref {
    margin-top: var(--s4);
  }

  /* ---- Mobile ---- */
  @media (max-width: 820px) {
    .matters,
    .approach {
      grid-template-columns: 1fr;
    }

    .statute__ghost {
      font-size: 5.5rem;
    }

    .victory-memo__stamp {
      position: static;
      margin-bottom: var(--s3);
    }

    .file-section {
      padding: var(--s5) 0;
    }
  }
</style>
