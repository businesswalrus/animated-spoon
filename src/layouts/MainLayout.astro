---
/**
 * MainLayout.astro — the Bureau of Road Fairness document shell.
 * Every page is filed on this letterhead: parody .gov banner → letterhead →
 * blotter/sheet/rail document grid → doc-footer form strip.
 */
import '@fontsource/oswald/500.css';
import '@fontsource/oswald/600.css';
import '@fontsource/oswald/700.css';
/* Public Sans is the U.S. government's own typeface (USWDS). That is the joke. */
import '@fontsource/public-sans/400.css';
import '@fontsource/public-sans/400-italic.css';
import '@fontsource/public-sans/500.css';
import '@fontsource/public-sans/700.css';
import '@fontsource/courier-prime/400.css';
import '@fontsource/courier-prime/700.css';
import '../styles/global.css';

import { STATES } from '../data/states';
import { getAllCountries } from '../data/countries';
import Seal from '../components/Seal.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description?: string;
  docket?: string;
  formNumber?: string;
  revision?: string;
  ogImage?: string;
}

const {
  title,
  description = 'The AARBAA Bureau of Road Fairness — official records, field offices, and public filings of the Americans Against Road Bikers Association of America.',
  docket = 'AAR-000 · GENERAL FILE',
  formNumber = 'FORM AAR-000',
  revision = 'REV. 07/2026',
  ogImage = '/images/og-card.png',
} = Astro.props;

const site = Astro.site ?? new URL('https://aarbaa.com');
const canonical = new URL(Astro.url.pathname, site);
const ogImageAbs = new URL(ogImage, site);

const sortedStates = [...STATES].sort((a, b) => a.name.localeCompare(b.name));
const sortedCountries = [...getAllCountries()].sort((a, b) => a.name.localeCompare(b.name));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#041E42" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <slot name="head" />
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to main content</a>

    <!-- PARODY .GOV BANNER — the top screenshot moment; executed pixel-close to USWDS -->
    <details class="gov-banner">
      <summary>
        <span class="gov-banner__inner">
          <span class="gov-banner__flag"><Icon name="flag" size={12} /></span>
          <span
            >An official website of the Americans Against Road Bikers Association of America.
            <span class="gov-banner__how">Here&rsquo;s how you know</span></span
          >
        </span>
      </summary>
      <div class="gov-banner__content">
        <div class="gov-banner__item">
          <Icon name="seal" size={22} />
          <div>
            <strong>Official AARBAA websites use the letterhead of the Bureau of Road Fairness.</strong>
            <p>
              Correspondence presented without letterhead has not been issued by the Bureau and
              should be reported to your regional field office on Form AAR-119 (Report of
              Irregular Correspondence). The Bureau does not acknowledge unlettered paper.
            </p>
          </div>
        </div>
        <div class="gov-banner__item">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="square"
            aria-hidden="true"
          >
            <rect x="5" y="10" width="14" height="10"></rect>
            <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
            <path d="M12 14v3"></path>
          </svg>
          <div>
            <strong>A locked padlock means information you file travels to the Bureau intact.</strong>
            <p>
              Filings received intact are retained under Records Retention Schedule 7, whether or
              not they are read. Estimated retention period: indefinite.
            </p>
          </div>
        </div>
      </div>
    </details>

    <!-- LETTERHEAD -->
    <header class="letterhead">
      <div class="letterhead__inner">
        <a class="letterhead__brand" href="/" aria-label="AARBAA — Bureau of Road Fairness home">
          <span class="letterhead__seal"><Seal size="40px" tone="paper" /></span>
          <span class="letterhead__lockup">
            <!-- Bracket wordmark, inlined with token fills on the navy plate:
                 the white "RB" is permanently visible here. -->
            <svg
              class="wordmark letterhead__wordmark"
              viewBox="0 0 257.62 100.83"
              aria-hidden="true"
            >
              <path
                class="wm-red"
                d="M46.72,30.94l17.56,43.52h-10.65l-3.23-8.71h-16.56l-3.21,8.71h-10.67l17.56-43.52h9.19ZM47.04,57.05l-4.85-12.65h-.1l-4.85,12.65h9.81Z"
              ></path>
              <path
                class="wm-red"
                d="M83.6,30.94l17.56,43.52h-10.65l-3.23-8.71h-16.56l-3.21,8.71h-10.67l17.56-43.52h9.19ZM83.91,57.05l-4.85-12.65h-.1l-4.85,12.65h9.81Z"
              ></path>
              <path
                class="wm-paper"
                d="M98.37,30.94h15.56c4.18,0,7.59,1.12,10.23,3.35,2.63,2.24,3.96,5.43,3.96,9.56,0,3.21-.8,5.9-2.4,8.06-1.6,2.16-3.77,3.68-6.52,4.56l14.98,17.98h-12.6l-13.29-17.19v17.19h-9.92V30.94ZM108.29,50.25h1.17c.9,0,1.67-.01,2.31-.04.64-.04,1.36-.17,2.17-.38.8-.22,1.45-.52,1.94-.9.5-.39.92-.95,1.27-1.69.36-.75.54-1.65.54-2.71s-.18-1.95-.54-2.69c-.35-.74-.77-1.3-1.27-1.69-.49-.38-1.13-.69-1.94-.9-.81-.21-1.53-.32-2.17-.35-.64-.04-1.41-.06-2.31-.06h-1.17v11.4Z"
              ></path>
              <path
                class="wm-paper"
                d="M131.65,30.94h13.5c4.08,0,7.33.88,9.75,2.62,2.43,1.74,3.65,4.56,3.65,8.46,0,4.37-1.81,7.47-5.44,9.33,6.19,1.08,9.29,4.75,9.29,10.98,0,3.66-1.27,6.59-3.81,8.81-2.53,2.21-6.01,3.31-10.44,3.31h-16.5V30.94ZM141.57,47.98h.79c2.21,0,3.85-.38,4.94-1.15,1.09-.78,1.64-2.05,1.64-3.81,0-2.96-2.2-4.44-6.58-4.44h-.79v9.4ZM141.57,66.82h3.11c4.86,0,7.29-1.61,7.29-4.85,0-1.93-.61-3.32-1.83-4.17-1.21-.84-3.03-1.27-5.46-1.27h-3.11v10.29Z"
              ></path>
              <path
                class="wm-paper"
                d="M184.41,30.94l17.56,43.52h-10.65l-3.23-8.71h-16.56l-3.21,8.71h-10.67l17.56-43.52h9.19ZM184.72,57.05l-4.85-12.65h-.1l-4.85,12.65h9.81Z"
              ></path>
              <path
                class="wm-paper"
                d="M221.28,30.94l17.56,43.52h-10.65l-3.23-8.71h-16.56l-3.21,8.71h-10.67l17.56-43.52h9.19ZM221.6,57.05l-4.85-12.65h-.1l-4.85,12.65h9.81Z"
              ></path>
              <path class="wm-stroke-red" d="M.43,95.96h84.43"></path>
              <path class="wm-stroke-red" d="M5.19,18.23v82.46"></path>
              <path class="wm-stroke-paper" d="M252.86,4.96h-84.43"></path>
              <path class="wm-stroke-paper" d="M252.42,82.31V-.15"></path>
            </svg>
            <span class="letterhead__bureau">BUREAU OF ROAD FAIRNESS — OFFICE OF PUBLIC AWARENESS</span>
          </span>
        </a>

        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
          MENU
        </button>

        <nav class="letterhead__nav" id="primary-nav" aria-label="Primary">
          <ul class="nav-list">
            <li><a href="/about">About</a></li>
            <li>
              <details class="nav-details">
                <summary>Field Offices</summary>
                <div class="nav-panel">
                  <p class="nav-panel__head">
                    CLASSIFIED DIRECTORY — DOMESTIC FIELD OFFICES · 50 RECORDS ON FILE
                  </p>
                  <ul class="nav-panel__grid">
                    {
                      sortedStates.map((state) => (
                        <li>
                          <a href={`/chapters/${state.slug}`}>
                            <span class="nav-panel__abbr">{state.abbreviation}</span>
                            {state.name}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                  <a class="nav-panel__all" href="/chapters">DIRECTORY OF ALL FIELD OFFICES →</a>
                </div>
              </details>
            </li>
            <li>
              <details class="nav-details">
                <summary>International</summary>
                <div class="nav-panel">
                  <p class="nav-panel__head">
                    CLASSIFIED DIRECTORY — INTERNATIONAL LIAISON OFFICES · {sortedCountries.length} RECORDS ON FILE
                  </p>
                  <ul class="nav-panel__grid">
                    {
                      sortedCountries.map((country) => (
                        <li>
                          <a href={`/countries/${country.slug}`}>
                            <span class="nav-panel__abbr">{country.code}</span>
                            {country.name}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                  <a class="nav-panel__all" href="/countries">ALL INTERNATIONAL LIAISON OFFICES →</a>
                </div>
              </details>
            </li>
            <li><a href="/news">Records</a></li>
            <li><a href="/shop">Commissary</a></li>
            <li><a href="/resources">Reading Room</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a class="btn btn--primary" href="/join">File Form AAR-100</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- DOCUMENT -->
    <div class="blotter">
      <div class="sheet">
        <aside class="rail" aria-hidden="true">
          <span class="rail__docket">{docket} · {revision}</span>
        </aside>
        <main id="main" tabindex="-1">
          <slot />
        </main>
      </div>
    </div>

    <!-- DOCUMENT FOOTER -->
    <footer class="doc-footer">
      <div class="doc-footer__inner">
        <div>
          <Seal size="72px" tone="paper" />
          <p class="doc-footer__bureau">BUREAU OF ROAD FAIRNESS — OFFICE OF PUBLIC AWARENESS</p>
          <p class="doc-footer__copy">&copy; 2026 AARBAA. All filings final.</p>
        </div>

        <nav aria-label="Index">
          <p class="doc-footer__head">INDEX</p>
          <ul class="doc-footer__index">
            <li><a href="/about">About</a></li>
            <li><a href="/news">News</a></li>
            <li><a href="/chapters">Field Offices</a></li>
            <li><a href="/countries">International</a></li>
            <li><a href="/shop">Commissary</a></li>
            <li><a href="/resources">Reading Room</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/join">Join</a></li>
          </ul>
        </nav>

        <div data-mailing-list>
          <p class="doc-footer__head">MAILING LIST — FORM AAR-102</p>
          <div data-mailing-body>
            <form class="doc-footer__form">
              <label class="sr-only" for="footer-email">Electronic mail address</label>
              <input
                id="footer-email"
                type="email"
                name="email"
                placeholder="ELECTRONIC MAIL ADDRESS"
                required
              />
              <button class="btn btn--primary" type="submit">FILE</button>
            </form>
            <p class="doc-footer__note">Filings are reviewed in the order received.</p>
          </div>
        </div>
      </div>
      <p class="doc-footer__microline">
        {formNumber} · {revision} · RECORDS RETENTION SCHEDULE 7 · {docket}
      </p>
    </footer>

    <script>
      /* ---- Nav: one-open panels, Escape + outside click close, mobile drawer ---- */
      const header = document.querySelector('.letterhead');
      const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
      const drops = Array.from(document.querySelectorAll<HTMLDetailsElement>('details.nav-details'));

      toggle?.addEventListener('click', () => {
        const open = header?.classList.toggle('nav-open') ?? false;
        toggle.setAttribute('aria-expanded', String(open));
      });

      for (const drop of drops) {
        drop.addEventListener('toggle', () => {
          if (drop.open) {
            for (const other of drops) {
              if (other !== drop) other.open = false;
            }
          }
        });
      }

      document.addEventListener('click', (e) => {
        const target = e.target instanceof Node ? e.target : null;
        for (const drop of drops) {
          if (drop.open && target && !drop.contains(target)) drop.open = false;
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        for (const drop of drops) drop.open = false;
        if (header?.classList.contains('nav-open')) {
          header.classList.remove('nav-open');
          toggle?.setAttribute('aria-expanded', 'false');
        }
      });

      /* ---- Filing observer: .file-section → .is-filed (staggered), .redact → .is-open.
              Reduced motion renders final states instantly. ---- */
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const sections = Array.from(document.querySelectorAll<HTMLElement>('.file-section'));
      const redacts = Array.from(document.querySelectorAll<HTMLElement>('.redact'));

      if (reduceMotion || !('IntersectionObserver' in window)) {
        sections.forEach((s) => s.classList.add('is-filed'));
        redacts.forEach((r) => r.classList.add('is-open'));
      } else {
        const filer = new IntersectionObserver(
          (entries) => {
            let batchIndex = 0;
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target;
              if (el instanceof HTMLElement) {
                el.style.setProperty('--stagger-i', String(batchIndex++));
                el.classList.add('is-filed');
              }
              filer.unobserve(el);
            }
          },
          { threshold: 0.2 }
        );
        sections.forEach((s) => filer.observe(s));

        const releaser = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add('is-open');
              releaser.unobserve(entry.target);
            }
          },
          { threshold: 0.2 }
        );
        redacts.forEach((r) => releaser.observe(r));
      }

      /* ---- FORM AAR-102 mailing list: queued, never sent (no network) ---- */
      const mailingStrip = document.querySelector('[data-mailing-list]');
      const mailingForm = mailingStrip?.querySelector('form');
      mailingForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        const body = mailingStrip?.querySelector('[data-mailing-body]');
        if (body) {
          body.innerHTML =
            '<p class="doc-footer__queued">SUBMISSION QUEUED. ESTIMATED PROCESSING TIME: 6–8 WEEKS.</p>';
        }
      });
    </script>
  </body>
</html>
