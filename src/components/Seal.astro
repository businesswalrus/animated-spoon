---
/**
 * Seal.astro — the circular Bureau seal. Ring text on an SVG textPath around a
 * sedan-over-crossed-roads glyph. Single-color via `tone` so one SVG serves the
 * letterhead, footer, gold membership tier, and 4%-opacity watermark.
 * Always decorative (aria-hidden).
 */
interface Props {
  size?: string;
  tone?: 'ink' | 'gold' | 'paper';
  class?: string;
}

const { size = '96px', tone = 'ink', class: className } = Astro.props;

/* textPath needs a unique id per instance — pages may mount several seals */
const uid = `seal-ring-${Math.random().toString(36).slice(2, 8)}`;
---

<svg
  class:list={['seal', `seal--${tone}`, className]}
  style={`width:${size};height:${size}`}
  viewBox="0 0 120 120"
  aria-hidden="true"
>
  <circle cx="60" cy="60" r="57.5" fill="none" stroke="currentColor" stroke-width="2.5"></circle>
  <circle cx="60" cy="60" r="52.5" fill="none" stroke="currentColor" stroke-width="1"></circle>
  <circle cx="60" cy="60" r="33" fill="none" stroke="currentColor" stroke-width="1.5"></circle>

  <defs>
    <path id={uid} d="M60,60 m-42.5,0 a42.5,42.5 0 1,1 85,0 a42.5,42.5 0 1,1 -85,0"></path>
  </defs>
  <text
    fill="currentColor"
    font-family="'Courier Prime','Courier New',monospace"
    font-size="7"
    font-weight="700"
    letter-spacing="1"
  >
    <textPath href={`#${uid}`}>AMERICANS AGAINST ROAD BIKERS ASSOCIATION OF AMERICA &#9733; EST. 2023 &#9733;</textPath>
  </text>

  <!-- crossed road bars -->
  <g fill="currentColor">
    <rect x="39" y="57" width="42" height="6" transform="rotate(45 60 60)"></rect>
    <rect x="39" y="57" width="42" height="6" transform="rotate(-45 60 60)"></rect>
  </g>

  <!-- sedan silhouette over the crossing -->
  <g fill="currentColor" transform="translate(60 59)">
    <path d="M-16 5v-6l6-1.5 4-5.5h10l4 5.5 6 1.5v6z"></path>
    <circle cx="-8" cy="7" r="3.4"></circle>
    <circle cx="8" cy="7" r="3.4"></circle>
  </g>
</svg>

<style>
  .seal--ink {
    color: var(--ink);
  }

  .seal--gold {
    color: var(--gold-foil);
  }

  .seal--paper {
    color: var(--paper);
  }
</style>
