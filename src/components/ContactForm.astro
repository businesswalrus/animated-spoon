---
/**
 * ContactForm.astro — FORM AAR-101, REQUEST FOR ASSISTANCE.
 *
 * SACRED: the submit <script> below is ported VERBATIM from the previous
 * ContactForm.astro (webhook URL, email regex, payload shape, sessionStorage
 * personalization, /thank-you redirect). Only the chrome around it changed.
 * The webhook receives the exact same JSON: {name, email, phone, state, message}.
 */
interface Props {
  prefilledState?: string;
  formNumber?: string;
  heading?: string;
}

const {
  prefilledState,
  formNumber = 'AAR-101',
  heading = 'REQUEST FOR ASSISTANCE',
} = Astro.props;

// List of all 50 US states
const states = [
  "Alabama", "Alaska", "Arizona", "Arkansas", "California", "Colorado", "Connecticut", "Delaware",
  "Florida", "Georgia", "Hawaii", "Idaho", "Illinois", "Indiana", "Iowa", "Kansas", "Kentucky",
  "Louisiana", "Maine", "Maryland", "Massachusetts", "Michigan", "Minnesota", "Mississippi",
  "Missouri", "Montana", "Nebraska", "Nevada", "New Hampshire", "New Jersey", "New Mexico",
  "New York", "North Carolina", "North Dakota", "Ohio", "Oklahoma", "Oregon", "Pennsylvania",
  "Rhode Island", "South Carolina", "South Dakota", "Tennessee", "Texas", "Utah", "Vermont",
  "Virginia", "Washington", "West Virginia", "Wisconsin", "Wyoming"
];
---

<section class="form-kit">
  <header class="form-kit__head">
    <p class="form-kit__formno">FORM {formNumber} — {heading}</p>
    <h2 class="form-kit__title">{heading}</h2>
    <p class="form-kit__rev">REV. 07/2026 · APPROVED FOR PUBLIC USE · FILE IN DUPLICATE</p>
  </header>

  <div class="form-kit__body">
    <form id="contactForm">
      <div class="field">
        <label class="field__label" for="name">
          <span class="field__num">1.</span> NAME OF COMPLAINANT
        </label>
        <input type="text" id="name" name="name" autocomplete="name" required />
      </div>

      <div class="field">
        <label class="field__label" for="email">
          <span class="field__num">2.</span> ELECTRONIC MAIL ADDRESS
        </label>
        <input type="email" id="email" name="email" autocomplete="email" required />
      </div>

      <div class="field">
        <label class="field__label" for="phone">
          <span class="field__num">3.</span> TELEPHONE (OPTIONAL)
        </label>
        <input type="tel" id="phone" name="phone" autocomplete="tel" />
      </div>

      <div class="field">
        <label class="field__label" for="state">
          <span class="field__num">4.</span> STATE OF RESIDENCE
        </label>
        <select id="state" name="state" required>
          <option value="">Select your state...</option>
          {states.map((state) => (
            <option value={state} selected={prefilledState === state}>
              {state}
            </option>
          ))}
        </select>
      </div>

      <div class="field">
        <label class="field__label" for="message">
          <span class="field__num">5.</span> STATEMENT OF COMPLAINT
        </label>
        <textarea id="message" name="message" rows="5" required></textarea>
      </div>

      <div class="dead-zone" aria-hidden="true">
        DO NOT WRITE IN THIS SPACE — OFFICE USE ONLY
      </div>

      <p id="formNotice" class="form-kit__notice" role="alert" hidden></p>

      <button type="submit" class="btn btn--primary">SUBMIT FOR PROCESSING</button>

      <p class="form-kit__pra">
        Paperwork Reduction Act Notice — Estimated burden: 4 minutes per response,
        including time for reviewing instructions and composing grievances.
      </p>
    </form>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('contactForm');
  const notice = document.getElementById('formNotice');
  // Google Apps Script webhook URL
  const WEBHOOK_URL = 'https://script.google.com/macros/s/AKfycbyjj1VqHKID7Q-0vBB56zjqZViJ-OLENEKcnRdji66o9pkFLN6-jYK-3Gy6Vofr4ZHXVg/exec';

  const showNotice = (text) => {
    if (!notice) return;
    notice.hidden = false;
    notice.textContent = text;
  };
  const clearNotice = () => {
    if (!notice) return;
    notice.textContent = '';
    notice.hidden = true;
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearNotice();

    // Validate email
    const email = form.email.value;
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showNotice('FILING RETURNED — FIELD 2 (ELECTRONIC MAIL) FAILS FORMAT VALIDATION. CORRECT AND RESUBMIT.');
      return;
    }

    // Collect form data
    const formData = {
      name: form.name.value,
      email: email,
      phone: form.phone.value || '',
      state: form.state.value,
      message: form.message.value
    };

    try {
      // POST to Google Apps Script
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        mode: 'no-cors', // Google Apps Script doesn't support CORS
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      // Store for thank you page personalization
      sessionStorage.setItem('contactFormData', JSON.stringify({
        name: formData.name,
        email: formData.email
      }));

      // Redirect to thank you page
      window.location.href = '/thank-you/';
    } catch (error) {
      showNotice('TRANSMISSION NOT ACCEPTED BY THE BUREAU. RETAIN YOUR COPY AND RESUBMIT ON FORM AAR-101.');
    }
  });
});
</script>

<style>
  /* Rejection strip — Courier register, consistent with FORM AAR-101 chrome. */
  .form-kit__notice {
    font-family: var(--font-type);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--glory-red);
    background: var(--paper);
    border: 1px solid var(--glory-red);
    border-left: 5px solid var(--glory-red);
    padding: var(--s3);
    margin: 0 0 var(--s3);
  }
</style>
